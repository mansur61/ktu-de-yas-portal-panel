@page "/"
@rendermode InteractiveServer

<PageTitle>Admin Panel - Ana Sayfa</PageTitle>

<div class="d-flex align-items-center gap-3 mb-4">
    <span class="bi bi-shield-lock-fill fs-1 text-primary"></span>
    <div>
        <h3 class="mb-0">KTU DeYas Admin Paneli</h3>
        <p class="text-muted mb-0">Yapı ve sensör yönetim platformu</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6 col-lg-4">
        <a href="structures" class="text-decoration-none">
            <div class="card card-structure border-primary h-100">
                <div class="card-body text-center py-5">
                    <span class="bi bi-building fs-1 text-primary"></span>
                    <h4 class="mt-3">Yapı Yönetimi</h4>
                    <p class="text-muted">Yeni yapı ekle, düzenle, sensör ata</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-lg-4">
        <a href="sensor-dashboard" class="text-decoration-none">
            <div class="card card-structure border-success h-100">
                <div class="card-body text-center py-5">
                    <span class="bi bi-activity fs-1 text-success"></span>
                    <h4 class="mt-3">Sensör Dashboard</h4>
                    <p class="text-muted">Canlı sensör verileri ve grafikler</p>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-6 col-lg-4">
        <a href="http://localhost:5050" target="_blank" class="text-decoration-none">
            <div class="card card-structure border-info h-100">
                <div class="card-body text-center py-5">
                    <span class="bi bi-box-arrow-up-right fs-1 text-info"></span>
                    <h4 class="mt-3">Kullanıcı Portalı</h4>
                    <p class="text-muted">KtuDeYasPortal'a git (localhost:5050)</p>
                </div>
            </div>
        </a>
    </div>
</div>
