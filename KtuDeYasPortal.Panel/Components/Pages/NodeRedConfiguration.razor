@page "/node-red-config"
@rendermode InteractiveServer
@using System.Text
@using System.Text.Json
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@inject IHttpClientFactory HttpClientFactory
@inject ILogger<NodeRedConfiguration> Logger
@inject IJSRuntime JS

<PageTitle>Node-RED Konfigürasyonu</PageTitle>

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">Node-RED Konfigürasyonu</h3>
            <p class="text-muted mb-0">Panel üzerinden yapı bazlı runtime ve custom flow planlarını edge servise iletir.</p>
        </div>
        <span class="badge bg-primary-subtle text-primary-emphasis px-3 py-2">Panel → Edge API</span>
    </div>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="alert @( _statusKind == "success" ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
            <div class="fw-semibold">@_statusMessage</div>
            <button type="button" class="btn-close" @onclick="ClearStatus"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-12 col-xl-7">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3">
                        <span class="bi bi-sliders me-2"></span>Konfigürasyon Planı
                    </h5>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Yapı</label>
                            <select class="form-select" value="@_request.StructureId" @onchange="OnStructureChanged" disabled="@_loadingStructures">
                                <option value="">@(_loadingStructures ? "Yapılar yükleniyor..." : "Yapı seçin")</option>
                                @foreach (var structure in _structures)
                                {
                                    <option value="@structure.Id">@structure.Name (@structure.StructureType)</option>
                                }
                            </select>
                            <div class="form-text">Yapı adı, türü ve ID seçilen yapıdan otomatik alınır.</div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Template Adı</label>
                            <input class="form-control" @bind="_request.TemplateName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Runtime Adı</label>
                            <input class="form-control" @bind="_request.RuntimeName" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Flow Kaynağı</label>
                            <select class="form-select" @bind="_request.FlowSource">
                                <option value="template">Template</option>
                                <option value="custom">Custom</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Kafka Topic</label>
                            <select class="form-select" @bind="_request.KafkaTopic">
                                @foreach (var topic in _kafkaTopics)
                                {
                                    <option value="@topic">@topic</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Topic Filter</label>
                            <select class="form-select" @bind="_request.TopicFilter">
                                @foreach (var filter in _topicFilters)
                                {
                                    <option value="@filter">@filter</option>
                                }
                            </select>
                            <div class="form-text">Seçilen yapının türü, ID'si ve sensör topic'lerinden üretilir.</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Custom Flow Dosyası</label>
                            <input class="form-control" @bind="_request.CustomFlowFileName" placeholder="ör. my-flow.json" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Environment Variables (JSON)</label>
                            <textarea class="form-control" rows="5" @bind="_request.EnvironmentVariablesJson"></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button class="btn btn-primary" @onclick="ConfigureAsync" disabled="@_isSubmitting">
                            @if (_isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            <span>Configure Et</span>
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="ResetForm">Temizle</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-5">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3">
                        <span class="bi bi-upload me-2"></span>Custom Flow Yükle
                    </h5>

                    <InputFile class="form-control" OnChange="OnFileSelected" accept=".json" />
                    <div class="form-text text-muted mt-2">Sadece .json dosyası kabul edilir.</div>

                    <button class="btn btn-outline-primary mt-3" @onclick="UploadCustomFlowAsync" disabled="@(_selectedFile is null || _isUploading)">
                        @if (_isUploading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <span>Yükle</span>
                    </button>

                    @if (_selectedFile is not null)
                    {
                        <div class="mt-3 small text-muted">Seçilen dosya: @_selectedFile.Name</div>
                    }
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3">
                        <span class="bi bi-table me-2"></span>Kayıtlı Konfigürasyonlar
                        <button class="btn btn-sm btn-outline-secondary float-end" @onclick="LoadConfigurationsAsync" disabled="@_loadingConfigList">
                            @if (_loadingConfigList)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            <span>Yenile</span>
                        </button>
                    </h5>

                    @if (_loadingConfigList)
                    {
                        <div class="text-center py-4 text-muted">Konfigürasyonlar yükleniyor...</div>
                    }
                    else if (_configurations.Count == 0)
                    {
                        <div class="text-muted py-4">Henüz kayıtlı Node-RED konfigürasyonu yok.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Yapı</th>
                                        <th>Runtime</th>
                                        <th>Template</th>
                                        <th>Kaynak</th>
                                        <th>Güncellendi</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var config in _configurations)
                                    {
                                        <tr>
                                            <td>@config.StructureName</td>
                                            <td>@config.RuntimeName</td>
                                            <td>@config.TemplateName</td>
                                            <td>@config.FlowSource</td>
                                            <td>@config.UpdatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteConfigurationAsync(config.StructureId, config.StructureName)" disabled="@_deletingConfigIds.Contains(config.StructureId)">
                                                    @if (_deletingConfigIds.Contains(config.StructureId))
                                                    {
                                                        <span class="spinner-border spinner-border-sm"></span>
                                                    }
                                                    <span>Sil</span>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3">
                        <span class="bi bi-terminal me-2"></span>Sonuç
                    </h5>
                    <pre class="bg-dark text-light rounded p-3 mb-0" style="white-space: pre-wrap; word-break: break-all;">@_resultText</pre>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private readonly NodeRedPanelRequest _request = new();
    private List<StructureOption> _structures = new();
    private List<string> _kafkaTopics = new() { "sensor.timeseries", "sensor.media", "sensor.video" };
    private List<string> _topicFilters = new();
    private bool _loadingStructures = true;

    private List<NodeRedConfigurationDto> _configurations = new();
    private bool _loadingConfigList = true;
    private HashSet<Guid> _deletingConfigIds = new();

    private IBrowserFile? _selectedFile;
    private bool _isSubmitting;
    private bool _isUploading;
    private string _resultText = "Bekleniyor...";
    private string _statusMessage = string.Empty;
    private string _statusKind = "success";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("timeseries-api");
            _structures = await client.GetFromJsonAsync<List<StructureOption>>("/api/structures") ?? new();
            var first = _structures.FirstOrDefault(s => s.IsActive) ?? _structures.FirstOrDefault();
            if (first is not null) ApplyStructure(first);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Node-RED yapı seçenekleri yüklenemedi");
            _statusMessage = "Yapılar yüklenemedi. Timeseries servisini kontrol edin.";
            _statusKind = "danger";
        }
        finally
        {
            _loadingStructures = false;
        }

        await LoadConfigurationsAsync();
    }

    private async Task LoadConfigurationsAsync()
    {
        _loadingConfigList = true;
        try
        {
            var client = HttpClientFactory.CreateClient("timeseries-api");
            _configurations = await client.GetFromJsonAsync<List<NodeRedConfigurationDto>>("/api/node-red-configurations")
                               ?? new List<NodeRedConfigurationDto>();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Node-RED konfigürasyonları yüklenemedi");
            _statusMessage = "Node-RED konfigürasyonları yüklenemedi.";
            _statusKind = "danger";
        }
        finally
        {
            _loadingConfigList = false;
        }
    }

    private async Task DeleteConfigurationAsync(Guid structureId, string structureName)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"'{structureName}' için kaydedilmiş konfigürasyon silinecek. Onaylıyor musunuz?");
        if (!confirmed) return;

        _deletingConfigIds.Add(structureId);
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient("timeseries-api");
            var response = await client.DeleteAsync($"/api/node-red-configurations/{structureId}");
            response.EnsureSuccessStatusCode();
            _statusMessage = "Konfigürasyon silindi.";
            _statusKind = "success";
            await LoadConfigurationsAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Node-RED konfigürasyonu silme hatası");
            _statusMessage = "Konfigürasyon silinirken hata oluştu.";
            _statusKind = "danger";
        }
        finally
        {
            _deletingConfigIds.Remove(structureId);
            StateHasChanged();
        }
    }

    private async Task ConfigureAsync()
    {
        _isSubmitting = true;
        _statusMessage = string.Empty;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient("edge-api");
            if (_request.StructureId == Guid.Empty)
                throw new InvalidOperationException("Önce bir yapı seçin.");

            var payload = new
            {
                structureId = _request.StructureId,
                structureName = _request.StructureName,
                structureType = _request.StructureType,
                templateName = _request.TemplateName,
                customFlowFileName = _request.CustomFlowFileName,
                flowSource = _request.FlowSource,
                runtimeName = _request.RuntimeName,
                topicFilter = _request.TopicFilter,
                kafkaTopic = _request.KafkaTopic,
                environmentVariables = ParseEnvironmentVariables(_request.EnvironmentVariablesJson)
            };

            using var response = await client.PostAsJsonAsync("/api/nodered/configure", payload);
            var body = await response.Content.ReadAsStringAsync();
            _resultText = body;
            _statusMessage = response.IsSuccessStatusCode ? "Konfigürasyon planı başarıyla oluşturuldu." : "Konfigürasyon planı oluşturulamadı.";
            _statusKind = response.IsSuccessStatusCode ? "success" : "danger";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Node-RED configure request failed");
            _resultText = ex.Message;
            _statusMessage = "İstek sırasında hata oluştu.";
            _statusKind = "danger";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task UploadCustomFlowAsync()
    {
        if (_selectedFile is null)
        {
            _statusMessage = "Önce bir .json dosyası seçin.";
            _statusKind = "danger";
            return;
        }

        _isUploading = true;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient("edge-api");
            using var content = new MultipartFormDataContent();
            await using var stream = _selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            content.Add(new StreamContent(stream), "file", _selectedFile.Name);

            using var response = await client.PostAsync($"/api/nodered/custom-flow?structureId={_request.StructureId}", content);
            var body = await response.Content.ReadAsStringAsync();
            _resultText = body;
            _statusMessage = response.IsSuccessStatusCode ? "Custom flow başarıyla yüklendi." : "Custom flow yüklenemedi.";
            _statusKind = response.IsSuccessStatusCode ? "success" : "danger";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Custom flow upload failed");
            _resultText = ex.Message;
            _statusMessage = "Yükleme sırasında hata oluştu.";
            _statusKind = "danger";
        }
        finally
        {
            _isUploading = false;
        }
    }

    private Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
        _resultText = $"Seçilen dosya: {_selectedFile.Name}";
        return Task.CompletedTask;
    }

    private void ResetForm()
    {
        var selected = _structures.FirstOrDefault(s => s.Id == _request.StructureId);
        if (selected is not null) ApplyStructure(selected);
        _request.CustomFlowFileName = string.Empty;
        _selectedFile = null;
        _resultText = "Bekleniyor...";
        _statusMessage = string.Empty;
    }

    private void ClearStatus() => _statusMessage = string.Empty;

    private void OnStructureChanged(ChangeEventArgs args)
    {
        if (Guid.TryParse(args.Value?.ToString(), out var id))
        {
            var selected = _structures.FirstOrDefault(s => s.Id == id);
            if (selected is not null) ApplyStructure(selected);
        }
    }

    private void ApplyStructure(StructureOption structure)
    {
        _request.StructureId = structure.Id;
        _request.StructureName = structure.Name;
        _request.StructureType = structure.StructureType;
        var type = NormalizeStructureType(structure.StructureType);
        _request.TemplateName = type switch { "baraj" => "Baraj", "kopru" => "Köprü", "tunel" => "Tünel", _ => "Center" };
        _request.RuntimeName = $"NodeRED-{_request.TemplateName}";
        _request.FlowSource = "template";
        _topicFilters = new List<string> { $"sensor/{type}/{structure.Id}/#", "sensor/#" };
        _request.TopicFilter = _topicFilters[0];
        _request.KafkaTopic = "sensor.timeseries";
        _request.EnvironmentVariablesJson = JsonSerializer.Serialize(new Dictionary<string, string>
        {
            ["STRUCTURE_ID"] = structure.Id.ToString(), ["STRUCTURE_TYPE"] = type,
            ["MQTT_TOPIC_FILTER"] = _request.TopicFilter, ["KAFKA_TOPIC"] = _request.KafkaTopic,
            ["NODE_RED_TEMPLATE"] = _request.TemplateName
        });
    }

    private static string NormalizeStructureType(string type) => type.Trim().ToLowerInvariant() switch
    {
        "bridge" or "köprü" or "kopru" => "kopru", "dam" or "baraj" => "baraj",
        "tunnel" or "tünel" or "tunel" => "tunel", _ => "center"
    };

    private static Dictionary<string, string> ParseEnvironmentVariables(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return new Dictionary<string, string>();

        try
        {
            return JsonSerializer.Deserialize<Dictionary<string, string>>(json)
                   ?? new Dictionary<string, string>();
        }
        catch
        {
            return new Dictionary<string, string>();
        }
    }

    private sealed class NodeRedPanelRequest
    {
        public Guid StructureId { get; set; }
        public string StructureName { get; set; } = string.Empty;
        public string StructureType { get; set; } = string.Empty;
        public string TemplateName { get; set; } = string.Empty;
        public string CustomFlowFileName { get; set; } = string.Empty;
        public string FlowSource { get; set; } = "template";
        public string RuntimeName { get; set; } = string.Empty;
        public string TopicFilter { get; set; } = string.Empty;
        public string KafkaTopic { get; set; } = string.Empty;
        public string EnvironmentVariablesJson { get; set; } = string.Empty;
    }

    private sealed class NodeRedConfigurationDto
    {
        public Guid StructureId { get; set; }
        public string StructureName { get; set; } = string.Empty;
        public string RuntimeName { get; set; } = string.Empty;
        public string TemplateName { get; set; } = string.Empty;
        public string FlowSource { get; set; } = string.Empty;
        public DateTime UpdatedAt { get; set; }
    }

    private sealed class StructureOption
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string StructureType { get; set; } = string.Empty;
        public bool IsActive { get; set; }
    }
}
