@page "/sensor-dashboard"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject SensorDashboardUseCases DashboardUC
@inject SensorDataState SensorDataState
@inject IOptions<GrafanaOptions> GrafanaOpts
@inject IJSRuntime JS

<PageTitle>Sensor Dashboard</PageTitle>

<h3>Sensor Dashboard <small class="text-muted fs-6">— Yapı Bazlı Zaman Serisi İzleme</small></h3>

@* ── Yükleniyor ─────────────────────────────────────────────────────────────── *@
@if (_loading)
{
    <div class="d-flex align-items-center gap-2 text-muted my-3">
        <div class="spinner-border spinner-border-sm" role="status"></div>
        <span>Yükleniyor...</span>
    </div>
}
else if (_structures is null || _structures.Count == 0)
{
    <div class="alert alert-info">
        Henüz yapı tanımlanmamış. Lütfen önce yönetim panelinden bir yapı oluşturun.
    </div>
}
else
{
    @* ── Yapı Sekmeleri ─────────────────────────────────────────────────────── *@
    <ul class="nav nav-tabs mb-0">
        @foreach (var st in _structures)
        {
            var isActive = st.Id == _selectedStructureId;
            <li class="nav-item">
                <a class="nav-link @(isActive ? "active" : "")"
                   href="javascript:void(0)"
                   @onclick="() => SelectStructureAsync(st.Id)">
                    <span class="bi bi-building me-1"></span>
                    @st.Name
                    <span class="badge bg-secondary ms-1">@st.SensorCount</span>
                </a>
            </li>
        }
    </ul>

    @* ── Sekme İçeriği ──────────────────────────────────────────────────────── *@
    <div class="tab-content border border-top-0 rounded-bottom p-3 mb-3">
        @if (_selectedStructure is null)
        {
            <div class="text-muted small">Yükleniyor...</div>
        }
        else if (_structureSensors.Count == 0)
        {
            <div class="alert alert-warning mb-0">
                <span class="bi bi-exclamation-triangle me-1"></span>
                Bu yapıya henüz sensör eklenmemiş.
            </div>
        }
        else
        {
            @* ── Prod Modu: Sensör Kurulum Durumu bölümü ─────────────────────── *@
            @if (_showLifecyclePanel)
            {
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center py-2"
                         style="background:linear-gradient(90deg,#1e3a5f,#2d5986)">
                        <span class="text-white fw-semibold">
                            <span class="bi bi-shield-check me-2"></span>Sensör Kurulum Durumu
                        </span>
                        <div class="d-flex gap-2 align-items-center">
                            @if (_lifecycleLoading)
                            {
                                <span class="spinner-border spinner-border-sm text-white-50"></span>
                            }
                            <button class="btn btn-sm btn-outline-light py-0"
                                    @onclick="RefreshLifecycleAsync" title="Yenile">
                                <span class="bi bi-arrow-clockwise"></span>
                            </button>
                            <button class="btn btn-sm btn-outline-light py-0"
                                    @onclick="() => _showLifecyclePanel = false" title="Gizle">
                                <span class="bi bi-chevron-up"></span>
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        @if (_lifecycleError is not null)
                        {
                            <div class="alert alert-danger m-2 py-2 small">
                                <span class="bi bi-exclamation-triangle me-1"></span>@_lifecycleError
                                <button class="btn-close float-end btn-sm py-0" @onclick="() => _lifecycleError = null"></button>
                            </div>
                        }
                        @if (_sensorReadinessMap.Count > 0)
                        {
                            <div class="table-responsive">
                                <table class="table table-sm table-hover mb-0" style="font-size:0.82rem">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Sensör</th>
                                            <th class="text-center" title="Bağlantı testi">🔌 Bağlantı</th>
                                            <th class="text-center" title="Parser doğrulama">⚙️ Parser</th>
                                            <th class="text-center" title="Metrik önizleme">📊 Metrikler</th>
                                            <th class="text-center">Durum</th>
                                            <th>Adımlar</th>
                                            <th>Eksikler</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var sensor in _structureSensors)
                                        {
                                            var r               = _sensorReadinessMap.GetValueOrDefault(sensor.SensorId);
                                            var lifecycleStatus = r?.ParsedLifecycleStatus ?? DeYas.Contracts.Sensors.SensorLifecycleStatus.Draft;
                                            var isRunning       = _activeSensorId == sensor.SensorId && _lifecycleLoading;

                                            // Adım aktiflik kuralları (lifecycle sırasına uygun)
                                            // 1. Bağlantı: her zaman çalıştırılabilir (yeniden test için)
                                            // 2. Parser: bağlantı başarılı olunca aktif
                                            // 3. Metrik Önizleme: parser başarılı olunca aktif
                                            bool canTestConnection   = !isRunning;
                                            bool canValidateParser   = !isRunning && (r?.ConnectionValid == true);
                                            bool canGeneratePreview  = !isRunning && (r?.ParserValid == true);

                                            <tr>
                                                <td>
                                                    <div class="fw-semibold" style="max-width:200px;white-space:normal;word-break:break-word"
                                                         title="@sensor.Name — @sensor.DeviceId">
                                                        @sensor.Name
                                                    </div>
                                                    <code class="text-muted" style="font-size:0.68rem">@sensor.DeviceId</code>
                                                    @if (!string.IsNullOrWhiteSpace(sensor.IpAddress))
                                                    {
                                                        <div style="font-size:0.68rem;color:#888">@sensor.IpAddress:@sensor.Port</div>
                                                    }
                                                </td>

                                                @* Bağlantı *@
                                                <td class="text-center align-middle">
                                                    @if (r is null)
                                                    {
                                                        <span class="badge bg-secondary">?</span>
                                                    }
                                                    else if (r.ConnectionValid)
                                                    {
                                                        <span class="badge bg-success" title="@r.LastConnectionTestAt?.ToLocalTime().ToString("dd.MM.yyyy HH:mm")">✓</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-danger" title="@r.LastConnectionTestError">✗</span>
                                                    }
                                                </td>

                                                @* Parser *@
                                                <td class="text-center align-middle">
                                                    @if (r is null)
                                                    {
                                                        <span class="badge bg-secondary">?</span>
                                                    }
                                                    else if (r.ParserValid)
                                                    {
                                                        <span class="badge bg-success">✓</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-warning text-dark" title="@r.LastParserValidationError">—</span>
                                                    }
                                                </td>

                                                @* Metrikler *@
                                                <td class="text-center align-middle">
                                                    @if (r is null)
                                                    {
                                                        <span class="badge bg-secondary">?</span>
                                                    }
                                                    else if (r.MetricPreviewValid && r.MetricCount > 0)
                                                    {
                                                        <span class="badge bg-success" title="@r.MetricCount metrik keşfedildi">@r.MetricCount</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-warning text-dark">0</span>
                                                    }
                                                </td>

                                                @* Lifecycle durumu *@
                                                <td class="text-center align-middle">
                                                    @{
                                                        var (bg, fg) = GetLifecycleBadgeStyle(lifecycleStatus);
                                                    }
                                                    <span class="badge" style="background:@bg; color:@fg; font-weight:600; font-size:0.7rem">
                                                        @lifecycleStatus.ToTurkish()
                                                    </span>
                                                </td>

                                                @* Adım butonları — lifecycle sırasına göre *@
                                                <td class="align-middle">
                                                    <div class="d-flex gap-1 flex-wrap">
                                                        @* 1. Bağlantı testi *@
                                                        <button class="btn btn-sm @(r?.ConnectionValid == true ? "btn-outline-success" : "btn-outline-primary")"
                                                                style="font-size:0.7rem;padding:2px 6px"
                                                                disabled="@(!canTestConnection)"
                                                                @onclick="() => RunConnectionTestAsync(sensor.SensorId)"
                                                                title="TCP bağlantısını test et ve sonucu kaydet">
                                                            @if (isRunning && _activeStep == "conn")
                                                            { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                            🔌 Bağlantı
                                                        </button>

                                                        @* 2. Parser doğrulama — bağlantı başarılı gerekli *@
                                                        <button class="btn btn-sm @(r?.ParserValid == true ? "btn-outline-success" : "btn-outline-secondary")"
                                                                style="font-size:0.7rem;padding:2px 6px"
                                                                disabled="@(!canValidateParser)"
                                                                @onclick="() => RunParserValidationAsync(sensor.SensorId)"
                                                                title="@(canValidateParser ? "Parser profilini doğrula" : "Önce bağlantı testini tamamlayın")">
                                                            @if (isRunning && _activeStep == "parser")
                                                            { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                            ⚙️ Parser
                                                        </button>

                                                        @* 3. Metrik önizleme — parser başarılı gerekli *@
                                                        <button class="btn btn-sm @(r?.MetricPreviewValid == true ? "btn-outline-success" : "btn-outline-secondary")"
                                                                style="font-size:0.7rem;padding:2px 6px"
                                                                disabled="@(!canGeneratePreview)"
                                                                @onclick="() => GenerateMetricPreviewAsync(sensor.SensorId)"
                                                                title="@(canGeneratePreview ? "Metrik önizleme oluştur" : "Önce parser doğrulamasını tamamlayın")">
                                                            @if (isRunning && _activeStep == "metric")
                                                            { <span class="spinner-border spinner-border-sm me-1"></span> }
                                                            📊 Metrikler
                                                        </button>
                                                    </div>
                                                </td>

                                                @* Eksik gereksinimler *@
                                                <td class="align-middle">
                                                    @if (r?.MissingRequirements?.Count > 0)
                                                    {
                                                        <small class="text-danger">
                                                            @string.Join(", ", r.MissingRequirements.Take(2))
                                                            @if (r.MissingRequirements.Count > 2) { <span title="@string.Join(", ", r.MissingRequirements)">…</span> }
                                                        </small>
                                                    }
                                                    else if (r?.IsReady == true)
                                                    {
                                                        <small class="text-success">
                                                            <span class="bi bi-check-circle me-1"></span>Hazır
                                                        </small>
                                                    }
                                                    else if (r is not null)
                                                    {
                                                        <small class="text-muted">—</small>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else if (!_lifecycleLoading)
                        {
                            <div class="p-3 text-muted small">
                                <span class="bi bi-info-circle me-1"></span>
                                Sensör doğrulama bilgisi yüklenemedi.
                                <button class="btn btn-link btn-sm p-0 ms-1" @onclick="RefreshLifecycleAsync">Yenile</button>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="mb-2">
                    <button class="btn btn-sm btn-outline-secondary"
                            @onclick="async () => { _showLifecyclePanel = true; await RefreshLifecycleAsync(); }">
                        <span class="bi bi-shield-check me-1"></span>Sensör Kurulum Durumunu Göster
                    </button>
                </div>
            }
            @* ── Sensör Filtresi (pill butonlar) ────────────────────────────── *@
            <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                <small class="text-muted fw-semibold me-1">Sensör:</small>

                @* "Tümü" butonu *@
                <button class="btn btn-sm @(_selectedSensorId == null ? "btn-primary" : "btn-outline-secondary")"
                        @onclick="() => SelectSensor(null)">
                    <span class="bi bi-grid me-1"></span>Tümü
                    <span class="badge bg-white text-dark ms-1" style="font-size:0.65rem">@_structureSensors.Count</span>
                </button>

                @* Her sensör için bir pill *@
                @foreach (var s in _structureSensors)
                {
                    var isSelected = _selectedSensorId == s.SensorId;
                    var liveCheck  = SensorDataState.GetLatest(s.DeviceId);
                    var dotColor   = liveCheck is not null ? "success" : "secondary";
                    <button class="btn btn-sm @(isSelected ? "btn-primary" : "btn-outline-secondary")"
                            @onclick="() => SelectSensor(s.SensorId)">
                        <span class="bi bi-circle-fill text-@dotColor me-1" style="font-size:0.45rem;vertical-align:middle"></span>
                        @s.Name
                    </button>
                }

                @* Zaman Aralığı — sağa yasla *@
                <div class="ms-auto d-flex align-items-center gap-2">
                    <label class="form-label small mb-0 text-muted">Aralık:</label>
                    <select class="form-select form-select-sm" style="width:auto"
                            @bind="_selectedRange" @bind:after="OnRangeChanged">
                        <option value="15m">15 dk</option>
                        <option value="1h">1 saat</option>
                        <option value="6h">6 saat</option>
                        <option value="24h">24 saat</option>
                        <option value="7d">7 gün</option>
                    </select>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshDataAsync" title="Yenile">
                        <span class="bi bi-arrow-clockwise"></span>
                    </button>
                </div>
            </div>

            <div class="row g-3 mb-3">
                @foreach (var sensor in GetVisibleSensors())
                {
                    var metrics  = GetSensorMetrics(sensor);
                    var liveData = SensorDataState.GetLatest(sensor.DeviceId);

                    @if (IsMediaSensor(sensor))
                    {
                        <div class="col-sm-6 col-md-4 col-xl-3">
                            <div class="card h-100 shadow-sm border-info border-opacity-50">
                                <div class="card-header py-2 bg-info bg-opacity-10 d-flex justify-content-between">
                                    <span class="fw-semibold small">📷 Kamera sensörü</span>
                                    <span class="badge bg-info text-dark">Medya</span>
                                </div>
                                <div class="card-body py-2 px-3">
                                    <div class="fw-semibold text-truncate">@sensor.Name</div>
                                    <div class="text-muted small text-truncate">@sensor.SensorType · @sensor.DeviceId</div>
                                    <div class="small mt-2 text-muted">Video/stream akışı merkez Node-RED ekranından izlenir.</div>
                                </div>
                            </div>
                        </div>
                    }

                    @foreach (var metric in metrics)
                    {
                        double?   val = null;
                        DateTime? ts  = null;

                        if (liveData is not null)
                        {
                            if (liveData.AllMetrics?.TryGetValue(metric, out var mv) == true)
                            { val = mv; ts = liveData.Timestamp; }
                            else if (string.Equals(liveData.MetricKey, metric, StringComparison.OrdinalIgnoreCase))
                            { val = liveData.CurrentValue; ts = liveData.Timestamp; }
                        }

                        var ageSec      = ts.HasValue
                            ? (DateTime.UtcNow - DateTime.SpecifyKind(ts.Value, DateTimeKind.Utc)).TotalSeconds
                            : double.MaxValue;
                        var statusColor = val.HasValue
                            ? (ageSec < 15 ? "success" : ageSec < 60 ? "warning" : "danger")
                            : "secondary";
                        var statusText  = val.HasValue
                            ? (ageSec < 15 ? "Canlı" : ageSec < 60 ? "Gecikmeli" : "Bağlantı Yok")
                            : "Veri Yok";
                        var isGrafanaActive = _grafanaDevice == sensor.DeviceId && _grafanaMetric == metric;

                        <div class="col-sm-6 col-md-4 col-xl-3">
                            <div class="card h-100 shadow-sm @(isGrafanaActive ? "border-primary" : "border-" + statusColor + " border-opacity-50")">
                                <div class="card-header py-2 d-flex justify-content-between align-items-center bg-@statusColor bg-opacity-10">
                                    <span class="fw-semibold small text-truncate" title="@sensor.Name — @metric">
                                        @GetMetricEmoji(metric) @GetMetricLabel(metric)
                                    </span>
                                    <span class="badge bg-@statusColor" style="font-size:0.65rem">@statusText</span>
                                </div>
                                <div class="card-body py-2 px-3">
                                    <div class="d-flex align-items-baseline gap-1 mb-1">
                                        @if (val.HasValue)
                                        {
                                            <span class="fs-3 fw-bold text-@statusColor lh-1">@val.Value.ToString("F2")</span>
                                            @if (!string.IsNullOrWhiteSpace(sensor.Unit))
                                            {
                                                <small class="text-muted">@sensor.Unit</small>
                                            }
                                        }
                                        else
                                        {
                                            <span class="fs-3 fw-bold text-secondary lh-1">—</span>
                                            @if (!string.IsNullOrWhiteSpace(sensor.Unit))
                                            {
                                                <small class="text-muted">@sensor.Unit</small>
                                            }
                                        }
                                    </div>
                                    <div class="text-muted text-truncate" style="font-size:0.72rem">
                                        <span class="bi bi-cpu me-1"></span>@sensor.Name
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mt-1" style="font-size:0.68rem">
                                        <code class="text-muted">@sensor.DeviceId</code>
                                        @if (ts.HasValue)
                                        {
                                            <span class="text-muted">
                                                @DateTime.SpecifyKind(ts.Value, DateTimeKind.Utc).ToLocalTime().ToString("HH:mm:ss")
                                            </span>
                                        }
                                    </div>
                                </div>
                                <div class="card-footer py-1 px-2 bg-transparent">
                                    <button class="btn btn-sm w-100 py-0 @(isGrafanaActive ? "btn-primary" : "btn-outline-secondary")"
                                            style="font-size:0.7rem"
                                            @onclick="() => ToggleGrafana(sensor.DeviceId, metric)">
                                        <span class="bi bi-bar-chart-line me-1"></span>
                                        @(isGrafanaActive ? "Grafana Açık" : "Grafana")
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            @* ── Grafana iframe ──────────────────────────────────────────────── *@
            @if (!string.IsNullOrEmpty(_iframeSrc))
            {
                <div class="card border-0 shadow-sm mt-2">
                    <div class="card-header d-flex justify-content-between align-items-center bg-dark text-white py-2">
                        <span>
                            <span class="bi bi-bar-chart-line me-1"></span>
                            @GetMetricEmoji(_grafanaMetric) @_grafanaMetric
                            <code class="text-white-50 ms-2" style="font-size:0.8rem">@_grafanaDevice</code>
                            <small class="text-white-50 ms-2">· @(_selectedStructure?.Name)</small>
                        </span>
                        <div class="d-flex gap-2">
                            <small class="text-white-50 align-self-center">@DateTime.UtcNow.ToLocalTime().ToString("HH:mm:ss")</small>
                            <button class="btn btn-sm btn-outline-light" @onclick="RefreshIframeAsync" title="Yenile">
                                <span class="bi bi-arrow-clockwise"></span>
                            </button>
                            <button class="btn btn-sm btn-outline-light" @onclick="OpenInNewTabAsync" title="Yeni Sekme">
                                <span class="bi bi-box-arrow-up-right"></span>
                            </button>
                            <button class="btn btn-sm btn-outline-light" @onclick="CloseGrafana" title="Kapat">
                                <span class="bi bi-x-lg"></span>
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <iframe src="@_iframeSrc"
                                width="100%"
                                height="600"
                                frameborder="0"
                                title="Grafana"
                                allow="fullscreen"
                                style="display:block;">
                        </iframe>
                    </div>
                </div>
            }
        }
    </div>
}

@code {
    // ── State ──────────────────────────────────────────────────────────────────
    private bool   _loading = true;
    private List<Domain.Entities.Structure>? _structures;
    private Guid   _selectedStructureId;
    private Domain.Entities.Structure? _selectedStructure;

    // Sensors of the selected structure (from GetByIdAsync — includes Sensors)
    private List<Domain.Entities.StructureSensor> _structureSensors = new();

    // Sensor filter: null = tümü, value = belirli sensörün SensorId'si
    private Guid? _selectedSensorId;

    // Kafka lag guard — current structure's device IDs
    private readonly HashSet<string> _structureDeviceSet =
        new(StringComparer.OrdinalIgnoreCase);

    // Grafana iframe
    private string _iframeSrc     = string.Empty;
    private string _grafanaDevice = string.Empty;
    private string _grafanaMetric = string.Empty;
    private string _selectedRange = "1h";

    private CancellationTokenSource? _cts;
    private PeriodicTimer?           _tick;

    // ── Lifecycle ──────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        SensorDataState.OnSensorDataReceived += OnSensorDataReceived;
        await LoadStructuresAsync();

        _cts  = new CancellationTokenSource();
        _tick = new PeriodicTimer(TimeSpan.FromSeconds(1));
        _ = TickAsync(_cts.Token);
    }

    // ── Load structure list ────────────────────────────────────────────────────
    private async Task LoadStructuresAsync()
    {
        _loading = true;
        try
        {
            _structures = await DashboardUC.GetAllStructuresAsync();
            if (_structures.Count > 0 && _selectedStructureId == Guid.Empty)
            {
                _selectedStructureId = _structures[0].Id;
                await LoadStructureDetailAsync(_structures[0].Id);
            }
        }
        finally { _loading = false; }
    }

    // ── Lifecycle panel state ─────────────────────────────────────────────────
    private bool   _showLifecyclePanel = true;
    private bool   _lifecycleLoading   = false;
    private string? _lifecycleError    = null;
    private Guid?  _activeSensorId;          // hangi sensörde işlem yapılıyor
    private string _activeStep = string.Empty; // "conn" | "parser" | "metric"
    private Dictionary<Guid, DeYas.Contracts.Sensors.SensorReadinessDto> _sensorReadinessMap = new();

    private async Task RefreshLifecycleAsync()
    {
        if (_structureSensors.Count == 0) return;
        _lifecycleLoading = true;
        StateHasChanged();
        try
        {
            // Her sensörün readiness'ını paralel çek (max 8 eş zamanlı)
            var semaphore = new SemaphoreSlim(8);
            var tasks = _structureSensors.Select(async ss =>
            {
                await semaphore.WaitAsync();
                try
                {
                    var r = await DashboardUC.GetSensorReadinessAsync(ss.SensorId);
                    return (ss.SensorId, Readiness: r);
                }
                catch { return (ss.SensorId, Readiness: (DeYas.Contracts.Sensors.SensorReadinessDto?)null); }
                finally { semaphore.Release(); }
            });

            var results = await Task.WhenAll(tasks);
            _sensorReadinessMap = results
                .Where(r => r.Readiness is not null)
                .ToDictionary(r => r.SensorId, r => r.Readiness!);
        }
        catch { /* best-effort */ }
        finally
        {
            _lifecycleLoading = false;
            StateHasChanged();
        }
    }

    // ── Load structure detail with sensors ────────────────────────────────────
    private async Task LoadStructureDetailAsync(Guid structureId)
    {
        _structureSensors.Clear();
        _structureDeviceSet.Clear();
        _selectedSensorId   = null;
        _sensorReadinessMap = new();

        var detail = await DashboardUC.GetStructureByIdAsync(structureId);
        _selectedStructure = detail;
        if (detail is null) return;

        _structureSensors = detail.Sensors
            .Where(s => s.IsActive && !string.IsNullOrWhiteSpace(s.DeviceId))
            .OrderBy(s => s.SensorOrder)
            .ToList();

        foreach (var s in _structureSensors)
            _structureDeviceSet.Add(s.DeviceId);

        // Lifecycle panel'i arka planda yükle
        _ = RefreshLifecycleAsync();
    }

    // ── Tab selection ──────────────────────────────────────────────────────────
    private async Task SelectStructureAsync(Guid id)
    {
        if (_selectedStructureId == id) return;
        _selectedStructureId = id;
        CloseGrafana();
        await LoadStructureDetailAsync(id);
        await InvokeAsync(StateHasChanged);
    }

    // ── Sensor filter ──────────────────────────────────────────────────────────
    private void SelectSensor(Guid? sensorId)
    {
        _selectedSensorId = sensorId;
        // Grafana'yı kapat — seçim değişince eski iframe geçersiz
        CloseGrafana();
    }

    // ── Grafana toggle ─────────────────────────────────────────────────────────
    private void ToggleGrafana(string deviceId, string metric)
    {
        // Aynı kart tekrar tıklanırsa kapat
        if (_grafanaDevice == deviceId && _grafanaMetric == metric)
        {
            CloseGrafana();
            return;
        }
        _grafanaDevice = deviceId;
        _grafanaMetric = metric;
        _iframeSrc = GrafanaOpts.Value.BuildPanelUrl(
            panelId: 10,
            metricVar: metric,
            deviceVar: deviceId,
            structureId: _selectedStructureId.ToString(),
            timeRange: _selectedRange);
    }

    private void CloseGrafana()
    {
        _iframeSrc     = string.Empty;
        _grafanaDevice = string.Empty;
        _grafanaMetric = string.Empty;
    }

    private void OnRangeChanged()
    {
        if (!string.IsNullOrEmpty(_iframeSrc))
            ToggleGrafana(_grafanaDevice, _grafanaMetric);
    }

    // ── Refresh ────────────────────────────────────────────────────────────────
    private async Task RefreshDataAsync()
    {
        await LoadStructuresAsync();
        if (_selectedStructureId != Guid.Empty)
            await LoadStructureDetailAsync(_selectedStructureId);
        await InvokeAsync(StateHasChanged);
    }

    private void OpenSensorManagement(Guid sensorId)
    {
        SelectSensor(sensorId);
        CloseGrafana();
    }

    private async Task RunConnectionTestAsync(Guid sensorId)
    {
        _lifecycleError = null;
        _activeSensorId = sensorId;
        _activeStep     = "conn";
        _lifecycleLoading = true;
        StateHasChanged();
        try
        {
            var sensor  = _structureSensors.FirstOrDefault(s => s.SensorId == sensorId);
            var request = new ConnectionTestRequestDto
            {
                IpAddress = sensor?.IpAddress,
                Port      = sensor?.Port,
                TimeoutMs = sensor?.TimeoutMs ?? 5000,
                Profile   = !string.IsNullOrWhiteSpace(sensor?.ProtocolType) ? sensor.ProtocolType : "Unknown",
                Encoding  = !string.IsNullOrWhiteSpace(sensor?.Encoding)     ? sensor.Encoding     : "utf-8"
            };
            await DashboardUC.TestConnectionLifecycleAsync(sensorId, request);
            await RefreshLifecycleAsync();
        }
        catch (Exception ex) { _lifecycleError = $"Bağlantı testi başarısız: {ex.Message}"; }
        finally
        {
            _lifecycleLoading = false;
            _activeSensorId   = null;
            _activeStep       = string.Empty;
            StateHasChanged();
        }
    }

