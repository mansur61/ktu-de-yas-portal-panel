@page "/sensor-dashboard"
@rendermode InteractiveServer
@inject SensorDashboardUseCases DashboardUC
@inject IJSRuntime JS

<PageTitle>Sensör Dashboard</PageTitle>

<h3>Sensör Dashboard <small class="text-muted fs-6">— Yapı Bazlı Zaman Serisi Grafikleri</small></h3>

@if (_structures is null)
{
    <p><em>Yükleniyor...</em></p>
}
else if (_structures.Count == 0)
{
    <div class="alert alert-info">Henüz yapı tanımlanmamış. Lütfen önce bir yapı oluşturun.</div>
}
else
{
    @* ── Yapı Seçici Tab'lar ── *@
    <ul class="nav nav-tabs sensor-tab mb-3">
        @foreach (var st in _structures)
        {
            var isActive = st.Id == _selectedStructureId;
            <li class="nav-item">
                <a class="nav-link @(isActive ? "active" : "")"
                   href="javascript:void(0)"
                   @onclick="() => SelectStructure(st.Id)">
                    <span class="bi bi-building me-1"></span>
                    @st.Name
                    <span class="badge bg-secondary ms-1">@st.SensorCount</span>
                </a>
            </li>
        }
    </ul>

    @if (_selectedStructure is not null)
    {
        @* ── Zaman aralığı seçici ── *@
        <div class="row g-2 mb-3 align-items-end">
            <div class="col-auto">
                <label class="form-label small">Zaman Aralığı</label>
                <select class="form-select form-select-sm" @bind="_selectedRange">
                    <option value="15m">Son 15 Dakika</option>
                    <option value="1h">Son 1 Saat</option>
                    <option value="6h">Son 6 Saat</option>
                    <option value="24h">Son 24 Saat</option>
                    <option value="7d">Son 7 Gün</option>
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label small">&nbsp;</label>
                <button class="btn btn-sm btn-primary d-block" @onclick="RefreshDataAsync">
                    <span class="bi bi-arrow-clockwise me-1"></span>Yenile
                </button>
            </div>
            <div class="col-auto">
                <label class="form-label small">&nbsp;</label>
                <button class="btn btn-sm btn-outline-success d-block" @onclick="StartAutoRefreshAsync" disabled="@_autoRefresh">
                    <span class="bi bi-play-fill me-1"></span>Canlı Takip
                </button>
            </div>
            <div class="col-auto" hidden="@(!_autoRefresh)">
                <label class="form-label small">&nbsp;</label>
                <button class="btn btn-sm btn-outline-danger d-block" @onclick="StopAutoRefresh">
                    <span class="bi bi-stop-fill me-1"></span>Durdur
                </button>
            </div>
        </div>

        if (_loading)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Yükleniyor...</span>
                </div>
                <p class="mt-2 text-muted">Veriler yükleniyor...</p>
            </div>
        }
        else if (_chartData.Count == 0)
        {
            <div class="alert alert-info">Seçilen zaman aralığında veri bulunamadı.</div>
        }
        else
        {
            @* ── Metrik seçici tab'lar ── *@
            <ul class="nav nav-pills mb-3 gap-1">
                @foreach (var metricKey in _availableMetrics)
                {
                    var isActiveMetric = metricKey == _selectedMetric;
                    <li class="nav-item">
                        <a class="nav-link @(isActiveMetric ? "active" : "")"
                           href="javascript:void(0)"
                           @onclick="() => SelectMetric(metricKey)">
                            @GetMetricLabel(metricKey)
                        </a>
                    </li>
                }
            </ul>

            @* ── Grafik ── *@
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">
                        @GetMetricLabel(_selectedMetric)
                        <small class="text-muted fs-6">— @_selectedStructure.Name</small>
                    </h5>
                    <div style="position:relative;width:100%;max-height:350px">
                        <canvas id="sensorChart" width="800" height="350"
                                style="width:100%;max-height:350px"></canvas>
                    </div>
                </div>
            </div>

            @* ── Ham veri tablosu ── *@
            <div class="card mt-3">
                <div class="card-header">
                    <span class="bi bi-table me-1"></span> Son Veriler
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height:250px">
                        <table class="table table-sm table-striped mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th>Zaman</th>
                                    <th>Cihaz</th>
                                    @foreach (var m in _availableMetrics)
                                    {
                                        <th>@GetMetricLabel(m)</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in _chartData.OrderByDescending(x => x.Timestamp).Take(20))
                                {
                                    <tr>
                                        <td><small>@row.Timestamp.ToLocalTime().ToString("HH:mm:ss")</small></td>
                                        <td><code>@row.DeviceId</code></td>
                                        @foreach (var m in _availableMetrics)
                                        {
                                            var val = row.Metrics.ContainsKey(m) ? row.Metrics[m].ToString("F2") : "-";
                                            <td><span class="badge bg-secondary metric-badge">@val</span></td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
}

@code {
    private List<Domain.Entities.Structure>? _structures;
    private Guid _selectedStructureId;
    private Domain.Entities.Structure? _selectedStructure;
    private bool _loading;
    private string _selectedRange = "1h";
    private string _selectedMetric = "temperature";
    private bool _autoRefresh;
    private CancellationTokenSource? _autoRefreshCts;

    private List<SensorDataPoint> _chartData = new();
    private readonly List<string> _availableMetrics = new()
    {
        "temperature", "humidity", "pressure", "vibration", "wind_speed", "water_level"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadStructuresAsync();
        if (_structures?.Count > 0)
        {
            _selectedStructureId = _structures[0].Id;
            _selectedStructure = _structures[0];
            await RefreshDataAsync();
        }
    }

    private async Task LoadStructuresAsync()
    {
        _structures = await DashboardUC.GetAllStructuresAsync();
    }

    private async Task SelectStructure(Guid id)
    {
        _selectedStructureId = id;
        _selectedStructure = _structures?.FirstOrDefault(s => s.Id == id);
        await RefreshDataAsync();
    }

    private async Task RefreshDataAsync()
    {
        _loading = true;
        try
        {
            var (from, to) = GetTimeRange();
            var allData = new List<SensorDataPoint>();

            if (_selectedStructure?.Sensors is not null)
            {
                foreach (var sensor in _selectedStructure.Sensors.Where(s => s.IsActive))
                {
                    var data = await DashboardUC.QueryTimeseriesAsync(
                        sensor.DeviceId, null, from, to, 500);
                    allData.AddRange(data);
                }
            }

            _chartData = allData;
            await RenderChart();
        }
        finally
        {
            _loading = false;
        }
    }

    private (DateTime from, DateTime to) GetTimeRange()
    {
        var to = DateTime.UtcNow;
        var from = _selectedRange switch
        {
            "15m" => to.AddMinutes(-15),
            "1h" => to.AddHours(-1),
            "6h" => to.AddHours(-6),
            "24h" => to.AddHours(-24),
            "7d" => to.AddDays(-7),
            _ => to.AddHours(-1)
        };
        return (from, to);
    }

    private async Task SelectMetric(string metric)
    {
        _selectedMetric = metric;
        await RenderChart();
    }

    private async Task RenderChart()
    {
        if (_chartData.Count == 0) return;

        var filtered = _chartData
            .Where(d => d.Metrics.ContainsKey(_selectedMetric))
            .OrderBy(d => d.Timestamp)
            .ToList();

        if (filtered.Count == 0) return;

        var labels = filtered.Select(d => d.Timestamp.ToLocalTime().ToString("HH:mm:ss")).ToList();
        var values = filtered.Select(d => d.Metrics[_selectedMetric]).ToList();
        var labelName = GetMetricLabel(_selectedMetric);

        try
        {
            await JS.InvokeVoidAsync("renderChart", "sensorChart", labels, values, labelName);
        }
        catch { /* JS not loaded yet */ }
    }

    private async Task StartAutoRefreshAsync()
    {
        _autoRefresh = true;
        _autoRefreshCts = new CancellationTokenSource();

        try
        {
            while (!_autoRefreshCts.Token.IsCancellationRequested)
            {
                await Task.Delay(5000, _autoRefreshCts.Token);
                await RefreshDataAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
    }

    private void StopAutoRefresh()
    {
        _autoRefresh = false;
        _autoRefreshCts?.Cancel();
    }

    private static string GetMetricLabel(string key) => key switch
    {
        "temperature" => "🌡️ Sıcaklık",
        "humidity" => "💧 Nem",
        "pressure" => "🔽 Basınç",
        "vibration" => "📳 Titreşim",
        "wind_speed" => "💨 Rüzgar Hızı",
        "water_level" => "🌊 Su Seviyesi",
        _ => key
    };

    public void Dispose()
    {
        StopAutoRefresh();
    }
}
