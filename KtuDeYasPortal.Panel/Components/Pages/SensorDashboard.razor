    private async Task GenerateMetricPreviewAsync(Guid sensorId)
    {
        _lifecycleError = null;
        _activeSensorId = sensorId;
        _activeStep     = "metric";
        _lifecycleLoading = true;
        StateHasChanged();
        try
        {
            var sensor = _structureSensors.FirstOrDefault(s => s.SensorId == sensorId);
            // Parser doğrulamasından gelen mevcut metrik listesini kullan,
            // yoksa sensörün Metrics alanından türet
            var metricKeys = GetSensorMetrics(sensor!);
            var request = new GenerateMetricPreviewRequestDto
            {
                ParserProfile = sensor?.ProtocolType,
                Metrics       = metricKeys
                    .Select(m => new MetricPreviewInputDto { MetricCode = m })
                    .ToList()
            };
            // Metrik listesi boşsa Unknown profil ile en az 1 placeholder ekle
            if (request.Metrics.Count == 0)
                request.Metrics.Add(new MetricPreviewInputDto { MetricCode = "value" });

            await DashboardUC.GenerateMetricPreviewAsync(sensorId, request);
            await RefreshLifecycleAsync();
        }
        catch (Exception ex) { _lifecycleError = $"Metrik önizleme oluşturulamadı: {ex.Message}"; }
        finally
        {
            _lifecycleLoading = false;
            _activeSensorId   = null;
            _activeStep       = string.Empty;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Lifecycle durumuna göre badge arka plan ve yazı renklerini döner.
    /// Bootstrap sınıfı yerine inline style — tüm durumları kapsar.
    /// </summary>
    private static (string Bg, string Fg) GetLifecycleBadgeStyle(
        DeYas.Contracts.Sensors.SensorLifecycleStatus status)
    {
        return status switch
        {
            DeYas.Contracts.Sensors.SensorLifecycleStatus.Draft                  => ("#e9ecef", "#495057"),
            DeYas.Contracts.Sensors.SensorLifecycleStatus.ConnectionTesting      => ("#cfe2ff", "#084298"),
            DeYas.Contracts.Sensors.SensorLifecycleStatus.ConnectionFailed       => ("#f8d7da", "#842029"),
            DeYas.Contracts.Sensors.SensorLifecycleStatus.ConnectionTested       => ("#d1e7dd", "#0a3622"),
            DeYas.Contracts.Sensors.SensorLifecycleStatus.ParserValidating       => ("#fff3cd", "#664d03"),
            DeYas.Contracts.Sensors.SensorLifecycleStatus.ParserInvalid          => ("#f8d7da", "#842029"),
            DeYas.Contracts.Sensors.SensorLifecycleStatus.ParserValidated        => ("#d1e7dd", "#0a3622"),
            DeYas.Contracts.Sensors.SensorLifecycleStatus.MetricPreviewPending   => ("#fff3cd", "#664d03"),
            DeYas.Contracts.Sensors.SensorLifecycleStatus.MetricPreviewGenerated => ("#d1e7dd", "#0a3622"),
            DeYas.Contracts.Sensors.SensorLifecycleStatus.Ready                  => ("#198754", "#fff"),
            DeYas.Contracts.Sensors.SensorLifecycleStatus.Starting               => ("#0d6efd", "#fff"),
            DeYas.Contracts.Sensors.SensorLifecycleStatus.Running                => ("#0d6efd", "#fff"),
            DeYas.Contracts.Sensors.SensorLifecycleStatus.Reconnecting           => ("#fd7e14", "#fff"),
            DeYas.Contracts.Sensors.SensorLifecycleStatus.Stopped               => ("#6c757d", "#fff"),
            DeYas.Contracts.Sensors.SensorLifecycleStatus.Faulted               => ("#dc3545", "#fff"),
            DeYas.Contracts.Sensors.SensorLifecycleStatus.Disabled              => ("#6c757d", "#fff"),
            _                                                                    => ("#e9ecef", "#495057"),
        };
    }

    // ── Realtime (Kafka lag guard) ─────────────────────────────────────────────
    private void OnSensorDataReceived(SensorUpdatedEvent evt)
    {
        if (!_structureDeviceSet.Contains(evt.DeviceId)) return;
        InvokeAsync(StateHasChanged);
    }

    // ── Helpers ────────────────────────────────────────────────────────────────
    private IEnumerable<Domain.Entities.StructureSensor> GetVisibleSensors() =>
        _selectedSensorId.HasValue
            ? _structureSensors.Where(s => s.SensorId == _selectedSensorId.Value)
            : _structureSensors;

    private static List<string> GetSensorMetrics(Domain.Entities.StructureSensor sensor)
    {
        if (IsMediaSensor(sensor)) return new();
        var csv = string.IsNullOrWhiteSpace(sensor.Metrics) ? sensor.Description : sensor.Metrics;
        if (string.IsNullOrWhiteSpace(csv)) return new();
        return csv.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
                  .Where(m => !string.IsNullOrWhiteSpace(m) &&
                              !string.Equals(m, "label", StringComparison.OrdinalIgnoreCase) &&
                              !string.Equals(m, "value", StringComparison.OrdinalIgnoreCase))
                  .ToList();
    }

    private static bool IsMediaSensor(Domain.Entities.StructureSensor sensor) =>
        sensor.SensorType.Contains("camera", StringComparison.OrdinalIgnoreCase) ||
        sensor.SensorType.Contains("video", StringComparison.OrdinalIgnoreCase) ||
        sensor.SensorType.Contains("stream", StringComparison.OrdinalIgnoreCase);

    private static string GetMetricLabel(string metric) => metric.ToLowerInvariant() switch
    {
        "temperature" => "Sıcaklık", "humidity" => "Nem", "pressure" => "Basınç",
        "vibration" => "Titreşim", "acceleration" => "İvme", "water_level" => "Su seviyesi",
        "wind_speed" => "Rüzgar hızı", "strain" => "Gerinim", "tilt" => "Eğim",
        "distance" => "Mesafe", _ => metric.Replace('_', ' ')
    };

    private static string GetMetricEmoji(string metric) => metric.ToLowerInvariant() switch
    {
        "temperature"  => "🌡️",
        "humidity"     => "💧",
        "pressure"     => "📊",
        "vibration"    => "📳",
        "acceleration" => "🚀",
        "wind_speed"   => "💨",
        "water_level"  => "🌊",
        "strain"       => "⚙️",
        "tilt"         => "📐",
        "distance"     => "📏",
        _              => "🔢"
    };

    // ── Iframe helpers ────────────────────────────────────────────────────────
    private async Task RefreshIframeAsync()
    {
        var saved = _iframeSrc;
        _iframeSrc = string.Empty;
        StateHasChanged();
        await Task.Delay(50);
        _iframeSrc = saved;
    }

    private async Task OpenInNewTabAsync()
    {
        if (!string.IsNullOrWhiteSpace(_iframeSrc))
            await JS.InvokeVoidAsync("open", _iframeSrc, "_blank");
    }

    // ── Tick ──────────────────────────────────────────────────────────────────
    private async Task TickAsync(CancellationToken ct)
    {
        try { while (await _tick!.WaitForNextTickAsync(ct)) await InvokeAsync(StateHasChanged); }
        catch (OperationCanceledException) { }
    }

    // ── Cleanup ───────────────────────────────────────────────────────────────
    public ValueTask DisposeAsync()
    {
        SensorDataState.OnSensorDataReceived -= OnSensorDataReceived;
        _cts?.Cancel();
        _tick?.Dispose();
        _cts?.Dispose();
        return ValueTask.CompletedTask;
    }
}
