@page "/sensor-dashboard"
@rendermode InteractiveServer
@inject SensorDashboardUseCases DashboardUC
@inject IConfiguration Configuration

<PageTitle>Sensor Dashboard</PageTitle>

<h3>Sensor Dashboard <small class="text-muted fs-6">- Yapı Bazlı Zaman Serisi Grafikleri</small></h3>

@if (_structures is null)
{
    <p><em>Yükleniyor...</em></p>
}
else if (_structures.Count == 0)
{
    <div class="alert alert-info">Henüz yapı tanımlanmamış. Lütfen önce bir yapı oluşturun.</div>
}
else
{
    <ul class="nav nav-tabs sensor-tab mb-3">
        @foreach (var st in _structures)
        {
            var isActive = st.Id == _selectedStructureId;
            <li class="nav-item">
                <a class="nav-link @(isActive ? "active" : "")"
                   href="javascript:void(0)"
                   @onclick="() => SelectStructure(st.Id)">
                    <span class="bi bi-building me-1"></span>
                    @st.Name
                    <span class="badge bg-secondary ms-1">@st.SensorCount</span>
                </a>
            </li>
        }
    </ul>

    @if (_selectedStructure is not null)
    {
        <div class="row g-2 mb-3 align-items-end">
            <div class="col-auto">
                <label class="form-label small">Zaman Aralığı</label>
                <select class="form-select form-select-sm" @bind="_selectedRange">
                    <option value="15m">Son 15 Dakika</option>
                    <option value="1h">Son 1 Saat</option>
                    <option value="6h">Son 6 Saat</option>
                    <option value="24h">Son 24 Saat</option>
                    <option value="7d">Son 7 Gün</option>
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label small">&nbsp;</label>
                <button class="btn btn-sm btn-primary d-block" @onclick="RefreshDataAsync">
                    <span class="bi bi-arrow-clockwise me-1"></span>Yenile
                </button>
            </div>
        </div>

        @if (_selectedStructure.Sensors is not { Count: > 0 })
        {
            <div class="alert alert-info">Bu yapı için sensör tanımı bulunamadı.</div>
        }
        else
        {
            <ul class="nav nav-pills mb-3 gap-1">
                @foreach (var metricKey in _availableMetrics)
                {
                    var isActiveMetric = metricKey == _selectedMetric;
                    <li class="nav-item">
                        <a class="nav-link @(isActiveMetric ? "active" : "")"
                           href="javascript:void(0)"
                           @onclick="() => SelectMetric(metricKey)">
                            @GetMetricLabel(metricKey)
                        </a>
                    </li>
                }
            </ul>

            <div class="grafana-solo-panel">
                <div class="grafana-solo-header">
                    <div>
                        <strong>@GetMetricLabel(_selectedMetric)</strong>
                        <small class="text-muted ms-2">- @_selectedStructure.Name</small>
                    </div>
                    <a class="btn btn-sm btn-outline-secondary"
                       href="@BuildGrafanaUrl(openDashboard: true)"
                       target="_blank">
                        <span class="bi bi-box-arrow-up-right me-1"></span>Ayrı Pencere
                    </a>
                </div>
                <iframe src="@BuildGrafanaUrl()"
                        class="grafana-solo-iframe"
                        title="Grafana Metric Panel"
                        allow="fullscreen"></iframe>
            </div>
        }
    }
}

@code {
    private List<Domain.Entities.Structure>? _structures;
    private Guid _selectedStructureId;
    private Domain.Entities.Structure? _selectedStructure;
    private string _selectedRange = "1h";
    private string _selectedMetric = "temperature";

    private readonly List<string> _availableMetrics = new()
    {
        "temperature", "humidity", "pressure", "acceleration", "vibration",
        "wind_speed", "water_level", "strain", "tilt", "distance"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadStructuresAsync();
        if (_structures?.Count > 0)
        {
            _selectedStructureId = _structures[0].Id;
            _selectedStructure = _structures[0];
        }
    }

    private async Task LoadStructuresAsync()
    {
        _structures = await DashboardUC.GetAllStructuresAsync();
    }

    private async Task SelectStructure(Guid id)
    {
        _selectedStructureId = id;
        _selectedStructure = _structures?.FirstOrDefault(s => s.Id == id);
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshDataAsync()
    {
        await LoadStructuresAsync();
        _selectedStructure = _structures?.FirstOrDefault(s => s.Id == _selectedStructureId) ?? _structures?.FirstOrDefault();
        if (_selectedStructure is not null)
            _selectedStructureId = _selectedStructure.Id;
        await InvokeAsync(StateHasChanged);
    }

    private async Task SelectMetric(string metric)
    {
        _selectedMetric = metric;
        await InvokeAsync(StateHasChanged);
    }

    private static string GetMetricLabel(string key) => key switch
    {
        "temperature" => "Sıcaklık",
        "humidity" => "Nem",
        "pressure" => "Basınç",
        "acceleration" => "İvme",
        "vibration" => "Titreşim",
        "wind_speed" => "Rüzgar Hızı",
        "water_level" => "Su Seviyesi",
        "strain" => "Strain",
        "tilt" => "Eğim",
        "distance" => "Mesafe",
        _ => key
    };

    private string BuildGrafanaUrl(bool openDashboard = false)
    {
        var baseUrl = (Configuration["Services:Grafana"] ?? "http://localhost:3000").TrimEnd('/');
        var uid = Configuration["Grafana:TimeseriesDashboardUid"] ?? "iot-platform-timeseries";
        var slug = Configuration["Grafana:TimeseriesDashboardSlug"] ?? "iot-platform-timescaledb";
        var panelId = Configuration["Grafana:MetricPanelId"] ?? "10";
        var deviceFilter = BuildDeviceFilter();
        var range = _selectedRange switch
        {
            "15m" => "now-15m",
            "1h" => "now-1h",
            "6h" => "now-6h",
            "24h" => "now-24h",
            "7d" => "now-7d",
            _ => "now-1h"
        };

        var path = openDashboard ? $"d/{uid}/{slug}" : $"d-solo/{uid}/{slug}";
        var query = new[]
        {
            "orgId=1",
            $"from={Uri.EscapeDataString(range)}",
            "to=now",
            $"var-device={Uri.EscapeDataString(deviceFilter)}",
            $"var-metric={Uri.EscapeDataString(_selectedMetric)}",
            $"panelId={Uri.EscapeDataString(panelId)}",
            "theme=light",
            "refresh=5s",
            "kiosk"
        };

        return $"{baseUrl}/{path}?{string.Join('&', query)}";
    }

    private string BuildDeviceFilter()
    {
        var devices = _selectedStructure?.Sensors?
            .Where(s => s.IsActive && !string.IsNullOrWhiteSpace(s.DeviceId))
            .Select(s => s.DeviceId)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        return devices is { Count: 1 } ? devices[0] : "%%";
    }
}
