    private async Task LoadStructuresAsync()
    {
        _structures = (await StructureUC.GetAllAsync()).OrderByDescending(s => s.CreatedAt).ToList();
    }

    private async Task StartStructureSimulationAsync(Guid structureId)
    {
        if (_startingStructureIds.Contains(structureId))
            return;

        _simulationErrorMessage = null;
        _simulationStatusMessage = null;

        var structure = _structures?.FirstOrDefault(s => s.Id == structureId);
        if (structure?.SensorCount == 0)
        {
            _simulationErrorMessage = $"{structure.Name} için sensör tanımlı değil; yapı çalıştırılamaz.";
            return;
        }

        _startingStructureIds.Add(structureId);

        try
        {
            await StructureSimClient.StartAsync(structureId);
            var structureName = structure?.Name ?? "yapı";
            _simulationStatusMessage = $"{structureName} için edge simülasyonu başlatıldı.";
            _runningStructureIds.Add(structureId);
        }
        catch (Exception ex)
        {
            _simulationErrorMessage = $"Simülasyon başlatılamadı: {ex.Message}";
        }
        finally
        {
            _startingStructureIds.Remove(structureId);
        }
    }

    private async Task StopStructureSimulationAsync(Guid structureId)
    {
        if (_stoppingStructureIds.Contains(structureId))
            return;

        _simulationErrorMessage  = null;
        _simulationStatusMessage = null;
        _stoppingStructureIds.Add(structureId);

        try
        {
            await StructureSimClient.StopAsync(structureId);
            var structureName = _structures?.FirstOrDefault(s => s.Id == structureId)?.Name ?? "yapı";
            _simulationStatusMessage = $"{structureName} simülasyonu durduruldu.";
            _runningStructureIds.Remove(structureId);
        }
        catch (Exception ex)
        {
            _simulationErrorMessage = $"Simülasyon durdurulamadı: {ex.Message}";
        }
        finally
        {
            _stoppingStructureIds.Remove(structureId);
        }
    }

    /// <summary>
    /// Yapıya özgü Node-RED dashboard ekranını (/ui) yeni sekmede açar.
    /// Flow editörü değil, canlı deploy (dashboard) görünümü açılır.
    /// Öncelik: structures.node_red_url (DB) → NodeRed:PerStructureUrls:{type} (config) → NodeRed:BaseUrl (fallback).
    /// </summary>
    private async Task OpenNodeRedAsync(Guid structureId, string structureName)
    {
        var structure = _structures?.FirstOrDefault(s => s.Id == structureId);

        // Yapıya özgü base URL — DB > config per-type > merkez fallback
        string baseUrl;
        if (!string.IsNullOrWhiteSpace(structure?.NodeRedUrl))
        {
            baseUrl = structure.NodeRedUrl.TrimEnd('/');
        }
        else if (structure?.StructureType is not null)
        {
            var perType = Configuration[$"NodeRed:PerStructureUrls:{structure.StructureType}"];
            baseUrl = !string.IsNullOrWhiteSpace(perType)
                ? perType.TrimEnd('/')
                : (Configuration["NodeRed:BaseUrl"] ?? "http://localhost:1880").TrimEnd('/');
        }
        else
        {
            baseUrl = (Configuration["NodeRed:BaseUrl"] ?? "http://localhost:1880").TrimEnd('/');
        }

        // #flow/tab-platform-pipeline → editör açılır ve doğrudan canlı akış tab'ına atlar.
        // Bu tab ID tüm per-structure instance'larda (baraj, köprü, ...) aynıdır.
        var url = baseUrl + "/api/ui/#flow/tab-platform-pipeline";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

    /// <summary>
    /// Merkez Node-RED dashboard ekranını (/ui) açar — tüm yapıların canlı akışını gösterir.
    /// </summary>
    private async Task OpenCentralNodeRedAsync()
    {
        var baseUrl = (Configuration["NodeRed:CentralUrl"]
                    ?? Configuration["NodeRed:BaseUrl"]
                    ?? "http://localhost:1880").TrimEnd('/');

        // Merkez instance'ın ana pipeline tab'ı: tab-monitor
        var url = baseUrl + "/api/ui/#flow/tab-monitor";
        await JS.InvokeVoidAsync("open", url, "_blank");
    }

