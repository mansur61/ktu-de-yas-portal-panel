    /// <summary>
    /// TCP/IP Sekmesinden sensör ekle
    /// </summary>
    private async Task SaveTcpSensorAsync()
    {
        // Validasyon
        if (string.IsNullOrWhiteSpace(_tcpSensorName) || 
            string.IsNullOrWhiteSpace(_tcpSensorType) ||
            string.IsNullOrWhiteSpace(_tcpIpAddress) ||
            !_tcpPort.HasValue)
        {
            _saveError = "Zorunlu alanları doldurunuz.";
            return;
        }

        if (_pendingPos == null) return;

        try
        {
            _isSaving = true;

                var sensorType = Enum.Parse<SensorType>(_tcpSensorType);
                var defaultMetrics = SensorMetricsConfiguration.GetMetrics(sensorType);
                var defaultUnit = SensorMetricsConfiguration.GetUnit(sensorType);

                // Yeni sensör oluştur
                var newSensor = new Sensor
                {
                    Id = Guid.NewGuid(),
                    Name = _tcpSensorName,
                    DeviceId = !string.IsNullOrWhiteSpace(_tcpDeviceId) ? _tcpDeviceId : _tcpSensorName,
                    SensorType = sensorType,
                    Description = _tcpDescription,
                    ProtocolType = _tcpProtocol,
                    IpAddress = _tcpIpAddress,
                    Port = _tcpPort,
                    TimeoutMs = _tcpTimeout,
                    PollingIntervalMs = _tcpPollInterval ?? 1000,
                    Topic = string.Empty, // Will be set by backend
                    Unit = defaultUnit,
                    Metrics = defaultMetrics,
                ImagePositionX = _pendingPos?.x,
                ImagePositionY = _pendingPos?.y,
                CreatedAt = DateTime.UtcNow,
                UpdatedAt = DateTime.UtcNow
            };

            if (_isWizardSensorMode)
            {
                // Wizard adım 3'te: listeye ekle
                _newStructureSensors.Add(newSensor);
            }
            else
            {
                // Mevcut yapı detayı: sensörü DB'ye oluştur, sonra yapıya bağla
                if (_editingStructure == null) return;

                var createdSensor = await StructureUC.CreateSensorAsync(newSensor);
                var sensorIds = _editingStructure.Sensors?.Select(x => x.SensorId).ToList() ?? new();
                sensorIds.Add(createdSensor.Id);
                await StructureUC.UpdateAsync(_editingStructure.Id, _editingStructure, sensorIds);
                _detailImageInitialized = false;
                await OpenStructureDetail(_editingStructure.Id);
            }

            CloseSensorPopup();
        }
        catch (Exception ex)
        {
            _saveError = $"Sensör kaydedilemedi: {ex.Message}";
        }
        finally 
        { 
            _isSaving = false;
        }
    }

    /// <summary>
    /// TCP/IP Sensör Form'unu sıfırla
    /// </summary>
    private void ResetTcpSensorForm()
    {
        _tcpSensorName = string.Empty;
        _tcpSensorType = string.Empty;
        _tcpIpAddress = string.Empty;
        _tcpPort = null;
        _tcpProtocol = "TCP";
        _tcpDeviceId = string.Empty;
        _tcpTimeout = 5000;
        _tcpPollInterval = 1000;
        _tcpDescription = string.Empty;
    }

