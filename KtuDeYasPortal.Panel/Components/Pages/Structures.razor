    // Sensör tipi değişince topic/unit/metrik otomatik doldur
    private void ResetSensorTypeDefaults(string typeKey)
    {
        _sensorFormType = typeKey;
        if (_typeDefaults.TryGetValue(typeKey, out var def))
        {
            var devId = string.IsNullOrWhiteSpace(_sensorFormDeviceId) ? "sensor" : _sensorFormDeviceId;

            // YENİ ŞEMA: sensor.{structureType}.{structureId}.{deviceId}
            // Örn: sensor.baraj.541ae3f0-6e30-4f48-96cb-62e7f9ba21c7.sensor-001
            // Wizard modunda (_editingStructure null): tip ve id henüz bilinmiyor, placeholder kullan
            if (_editingStructure != null)
            {
                var structType = _editingStructure.StructureType.ToString().ToLowerInvariant();
                var structId   = _editingStructure.Id.ToString().ToLowerInvariant();
                _sensorFormTopic = $"sensor.{structType}.{structId}.{devId}";
            }
            else if (_newType.HasValue)
            {
                // Wizard adım 3: yapı tipi seçildi ama ID henüz yok (DB'ye kaydedilmedi)
                var structType = _newType.Value.ToString().ToLowerInvariant();
                _sensorFormTopic = $"sensor.{structType}.{{structureId}}.{devId}";
            }
            else
            {
                _sensorFormTopic = $"sensor.other.{{structureId}}.{devId}";
            }

            _sensorFormUnit    = def.Unit;
            _sensorFormMetrics = new HashSet<string>(def.Metrics);
        }
    }

    /// <summary>
    /// Yapı adından URL-safe MQTT topic slug'ı üretir.
    /// "Yusufeli Barajı" → "yusufeli-baraji"
    /// </summary>
    private static string BuildTopicSlug(string name)
    {
        var map = new Dictionary<char, char>
        {
            ['ş'] = 's', ['Ş'] = 's', ['ğ'] = 'g', ['Ğ'] = 'g',
            ['ü'] = 'u', ['Ü'] = 'u', ['ö'] = 'o', ['Ö'] = 'o',
            ['ç'] = 'c', ['Ç'] = 'c', ['ı'] = 'i', ['İ'] = 'i'
        };

        var chars = name.ToLowerInvariant()
            .Select(ch => map.TryGetValue(ch, out var r) ? r : ch)
            .Select(ch => char.IsLetterOrDigit(ch) ? ch : '-')
            .ToArray();

        var slug = new string(chars);
        while (slug.Contains("--")) slug = slug.Replace("--", "-");
        return slug.Trim('-');
    }

    private void CloseSensorPopup()
    {
        _showSensorPopup = false;
        _pendingPos      = null;
        _addSensorTab    = "manual"; // Reset to manual tab
        ResetTcpSensorForm();
        _ = JS.InvokeVoidAsync("clearPendingClickPosition");
    }

    private async Task SaveSensorAsync()
    {
        if (_pendingPos == null) return;
        if (string.IsNullOrWhiteSpace(_sensorFormName) || string.IsNullOrWhiteSpace(_sensorFormDeviceId)) return;

        var metricsStr = _sensorFormMetrics.Any()
            ? string.Join(",", _sensorFormMetrics)
            : "";

        // Topic'te device ID placeholder varsa güncelle
        var finalTopic = _sensorFormTopic.Trim();
        if (finalTopic.Contains("sensor") && !string.IsNullOrWhiteSpace(_sensorFormDeviceId))
            finalTopic = finalTopic.Replace("sensor", _sensorFormDeviceId.Trim());

        var newSensor = new Sensor
        {
            Id                  = Guid.NewGuid(),
            Name                = _sensorFormName.Trim(),
            DeviceId            = _sensorFormDeviceId.Trim(),
            Topic               = finalTopic,
            Unit                = _sensorFormUnit.Trim(),
            Description         = _sensorFormDescription.Trim(),
            Metrics             = metricsStr,
            ProtocolType        = string.IsNullOrEmpty(_sensorFormProtocol) ? "MQTT" : _sensorFormProtocol,
            LocationId          = _sensorFormLabel.Trim().Length > 0 ? _sensorFormLabel.Trim() : "default",
            ImagePositionX      = _pendingPos.Value.x,
            ImagePositionY      = _pendingPos.Value.y,
            // saniye → ms dönüşümü; en az 1000 ms
            TelemetryIntervalMs = Math.Max(_sensorFormTelemetryIntervalSec, 1) * 1000,
            TelemetryBatchSize  = Math.Max(_sensorFormTelemetryBatchSize, 1),
            IsActive            = true,
            IsEnabled           = true,
        };
        if (Enum.TryParse<SensorType>(_sensorFormType, out var st))
            newSensor.SensorType = st;

        if (_isWizardSensorMode)
        {
            // Wizard: listeye ekle, resim üzerinde marker göster
            _newStructureSensors.Add(newSensor);
            _showSensorPopup = false;
            _pendingPos      = null;
            StateHasChanged();
            // Tüm marker'ları resim üzerinde yeniden render et (yeni eklenen dahil)
            var allMarkers = _newStructureSensors.Select(s => new {
                id = s.Id.ToString(), deviceId = s.DeviceId,
                name = s.Name, sensorType = s.SensorType.ToString(),
                unit = s.Unit, topic = s.Topic,
                imagePositionX = s.ImagePositionX, imagePositionY = s.ImagePositionY,
                status = s.IsActive ? "Online" : "Offline",
                lastValue = (double?)null,
                lastUpdated = (DateTime?)null, alertMessage = (string?)null
            }).ToList();
            try { await JS.InvokeVoidAsync("initStructureImage", "wizard-image",
                _structureTypes[_newType!.Value].ImagePath, allMarkers); }
            catch { }
        }
        else
        {
            // Mevcut yapı detayı: sensörü önce DB'ye oluştur, sonra yapıya bağla
            if (_editingStructure == null) return;
            _isSaving = true;
            try
            {
                var createdSensor = await StructureUC.CreateSensorAsync(newSensor);
                var sensorIds = _editingStructure.Sensors?.Select(x => x.SensorId).ToList() ?? new();
                sensorIds.Add(createdSensor.Id);
                await StructureUC.UpdateAsync(_editingStructure.Id, _editingStructure, sensorIds);
                _showSensorPopup        = false;
                _pendingPos             = null;
                _detailImageInitialized = false;
                await OpenStructureDetail(_editingStructure.Id);
            }
            catch (Exception ex)
            {
                _saveError = $"Sensör kaydedilemedi: {ex.Message}";
            }
            finally { _isSaving = false; }
        }
    }

    // ── Yapıdan sensör kaldır (resim üzerinden + listeden) ───────────────────
    private async Task RemoveSensorFromStructureAsync(Guid sensorId)
    {
        if (_editingStructure is null) return;
        _isSaving = true;
        try
        {
            // Sensör ID'sini listeden çıkar
            var remainingIds = _editingStructure.Sensors?
                .Where(s => s.SensorId != sensorId)
                .Select(s => s.SensorId)
                .ToList() ?? new();

            await StructureUC.UpdateAsync(_editingStructure.Id, _editingStructure, remainingIds);
            _detailImageInitialized = false;
            await OpenStructureDetail(_editingStructure.Id);
        }
        catch (Exception ex)
        {
            _saveError = $"Sensör silinemedi: {ex.Message}";
        }
        finally { _isSaving = false; }
    }

    private string GetSensorEmoji(string sensorTypeStr)
    {
        if (_sensorTypeInfos.TryGetValue(sensorTypeStr, out var info))
            return info.Emoji;
        // lowercase fallback
        var match = _sensorTypeInfos.FirstOrDefault(kv =>
            kv.Key.Equals(sensorTypeStr, StringComparison.OrdinalIgnoreCase));
        return match.Value?.Emoji ?? "🔘";
    }

    // ── Düzenleme ─────────────────────────────────────────────────────────────
    private void EditStructureInfo()
    {
        if (_editingStructure is null) return;
        _editName        = _editingStructure.Name;
        _editDescription = _editingStructure.Description ?? "";
        _editType        = _editingStructure.StructureType;
        _editProvince    = _editingStructure.Province;
        _editDistrict    = _editingStructure.District ?? "";
        _editAddress     = _editingStructure.Address ?? "";
        _editIsActive    = _editingStructure.IsActive;
        _editNodeRedUrl  = _editingStructure.NodeRedUrl ?? "";
        _editDistricts   = _districtMap.TryGetValue(_editProvince, out var d) ? d : new();
        _showEditPopup   = true;
    }

    private void OnEditProvinceChanged(ChangeEventArgs e)
    {
        _editProvince  = e.Value?.ToString() ?? "";
        _editDistrict  = "";
        _editDistricts = _districtMap.TryGetValue(_editProvince, out var d) ? d : new();
    }

    private async Task SaveEditAsync()
    {
        if (_editingStructure is null) return;
        _isSaving = true;
        try
        {
            _editingStructure.Name         = _editName;
            _editingStructure.Description  = _editDescription;
            _editingStructure.Province     = _editProvince;
            _editingStructure.District     = _editDistrict;
            _editingStructure.Address      = _editAddress;
            _editingStructure.StructureType = _editType;
            _editingStructure.IsActive     = _editIsActive;
            _editingStructure.ImageUrl     = _structureTypes[_editType].ImagePath;
            _editingStructure.NodeRedUrl   = string.IsNullOrWhiteSpace(_editNodeRedUrl) ? null : _editNodeRedUrl.Trim();

            var ids = _editingStructure.Sensors?.Select(s => s.SensorId).ToList() ?? new();
            await StructureUC.UpdateAsync(_editingStructure.Id, _editingStructure, ids);
            _showEditPopup = false;
            await LoadStructuresAsync();
        }
        finally { _isSaving = false; }
    }

    private void CloseEditPopup() => _showEditPopup = false;

    // ── Silme ─────────────────────────────────────────────────────────────────
    private void ConfirmDelete(Guid id) => _deletingId = id;

    private async Task DoDeleteAsync()
    {
        if (_deletingId is null) return;
        _isSaving = true;
        try
        {
            await StructureUC.DeleteAsync(_deletingId.Value);
            _deletingId       = null;
            _editingStructure = null;
            await LoadStructuresAsync();
        }
        finally { _isSaving = false; }
    }

    // ── Yardımcılar ───────────────────────────────────────────────────────────
