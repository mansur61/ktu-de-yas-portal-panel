    {
        _timerCts?.Cancel();
        _clickTimer?.Dispose();
        _timerCts?.Dispose();
        try { await JS.InvokeVoidAsync("disconnectSensorHub"); } catch { }
        try { await JS.InvokeVoidAsync("destroyMap"); } catch { }
    }
