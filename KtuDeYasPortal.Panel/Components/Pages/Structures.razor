    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await LoadStructuresAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _timerCts   = new CancellationTokenSource();
            _clickTimer = new PeriodicTimer(TimeSpan.FromMilliseconds(400));
            _ = PollClicksAsync(_timerCts.Token);
        }

        // Wizard adım 2 — harita DOM'a gelince init et
        if (_showCreateWizard && _wizardStep == 2 && !_mapInitialized)
        {
            _mapInitialized = true;
            try
            {
                await JS.InvokeVoidAsync("initMap", "new-map", _newLat, _newLng);
                if (!string.IsNullOrEmpty(_newProvince))
                    await JS.InvokeVoidAsync("panToProvince", _newProvince);
            }
            catch { }
        }
        // Wizard adım 2 dışında harita flag'ini sıfırla
        else if (!(_showCreateWizard && _wizardStep == 2))
        {
            _mapInitialized = false;
        }

        // Wizard adım 3 — yapı resmi DOM'a gelince init et
        if (_showCreateWizard && _wizardStep == 3 && !_wizardImageInitialized && _newType.HasValue)
        {
            _wizardImageInitialized = true;
            try
            {
                var imgPath = _structureTypes[_newType.Value].ImagePath;
                var markers = _newStructureSensors.Select(s => new {
                    id = s.Id.ToString(), deviceId = s.DeviceId,
                    name = s.Name, sensorType = s.SensorType.ToString(),
                    unit = s.Unit, topic = s.Topic,
                    imagePositionX = s.ImagePositionX, imagePositionY = s.ImagePositionY,
                    status = s.IsActive ? "Online" : "Offline",
                    lastValue = (double?)null,
                    lastUpdated = (DateTime?)null, alertMessage = (string?)null
                }).ToList();
                await JS.InvokeVoidAsync("initStructureImage", "wizard-image", imgPath, markers);
            }
            catch { }
        }
        else if (!(_showCreateWizard && _wizardStep == 3))
        {
            _wizardImageInitialized = false;
        }

        // Yapı detayı — resmi init et
        if (_editingStructure != null && !_detailImageInitialized)
        {
            _detailImageInitialized = true;
            await RenderStructureImageAsync();
        }
        else if (_editingStructure == null)
        {
            _detailImageInitialized = false;
        }
    }

    private async Task PollClicksAsync(CancellationToken ct)
    {
        while (await _clickTimer!.WaitForNextTickAsync(ct))
        {
            // Mevcut yapı detay sayfasında sensör ekle
            if (_editingStructure != null && !_showSensorPopup)
                await InvokeAsync(CheckPendingClickAsync);
            // Wizard adım 3'te sensör ekle
            else if (_showCreateWizard && _wizardStep == 3 && !_showSensorPopup)
                await InvokeAsync(CheckWizardPendingClickAsync);
        }
    }

