    private async Task SaveNewStructureAsync()
    {
        if (string.IsNullOrWhiteSpace(_newName) || string.IsNullOrEmpty(_newProvince) || _newType == null) return;
        _isSaving = true;
        try
        {
            var s = new Structure
            {
                Name          = _newName.Trim(),
                Description   = _newDescription.Trim(),
                IsActive      = _newIsActive,
                Province      = _newProvince,
                District      = _newDistrict,
                Address       = _newAddress.Trim(),
                Latitude      = _newLat,
                Longitude     = _newLng,
                StructureType = _newType.Value,
                ImageUrl      = _structureTypes[_newType.Value].ImagePath,
                NodeRedUrl    = string.IsNullOrWhiteSpace(_newNodeRedUrl) ? null : _newNodeRedUrl.Trim(),
                SensorCount   = _newStructureSensors.Count,
            };
            var created = await StructureUC.CreateAsync(s, new List<Guid>());

            // Wizard'da eklenen sensörleri önce DB'ye oluştur, sonra yapıya bağla
            if (_newStructureSensors.Any())
            {
                var createdIds = new List<Guid>();
                foreach (var sensor in _newStructureSensors)
                {
                    // Wizard'da topic'e {structureId} placeholder yazıldıysa
                    // gerçek ID ile değiştir
                    if (sensor.Topic.Contains("{structureId}"))
                    {
                        sensor.Topic = sensor.Topic.Replace(
                            "{structureId}",
                            created.Id.ToString().ToLowerInvariant());
                    }
                    var createdSensor = await StructureUC.CreateSensorAsync(sensor);
                    createdIds.Add(createdSensor.Id);
                }
                await StructureUC.UpdateAsync(created.Id, created, createdIds);
            }

            _showCreateWizard       = false;
            _wizardImageInitialized = false;
            _mapInitialized         = false;
            _newStructureSensors    = new();
            await JS.InvokeVoidAsync("destroyMap");
            await LoadStructuresAsync();
        }
        catch (Exception ex)
        {
            _saveError = $"Kayıt hatası: {ex.Message}";
        }
        finally { _isSaving = false; }
    }

