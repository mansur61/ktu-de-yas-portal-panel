@page "/structures"
@rendermode InteractiveServer
@using DeYas.Contracts.Sensors
@inject StructureUseCases StructureUC
@inject IStructureSimulationClient StructureSimClient
@inject IConfiguration Configuration
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Yapı Yönetimi</PageTitle>

@* ══════════════════════════════════════════════════════════════════
   ANA SAYFA — Liste + Başlık
   ══════════════════════════════════════════════════════════════════ *@
@if (_editingStructure == null && !_showCreateWizard)
{
    @if (!string.IsNullOrWhiteSpace(_simulationStatusMessage))
    {
        <div class="alert alert-success d-flex align-items-center gap-2 mb-3 py-2">
            <span class="bi bi-play-circle"></span>
            <div>@_simulationStatusMessage</div>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(_simulationErrorMessage))
    {
        <div class="alert alert-danger d-flex align-items-center gap-2 mb-3 py-2">
            <span class="bi bi-exclamation-triangle"></span>
            <div>@_simulationErrorMessage</div>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 fw-bold">Yapı Yönetimi</h4>
            <small class="text-muted">Kayıtlı yapılar, sensörler ve konum bilgileri</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-warning" @onclick="OpenCentralNodeRedAsync"
                    title="Merkez Node-RED — tüm yapıların MQTT akışını izler">
                <span class="bi bi-diagram-3-fill me-1"></span>Merkez Node-RED
            </button>
            <button class="btn btn-primary" @onclick="ShowCreateWizard">
                <span class="bi bi-plus-lg me-1"></span> Yeni Yapı
            </button>
        </div>
    </div>

    @if (_structures is null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Yükleniyor…</p>
        </div>
    }
    else if (_structures.Count == 0)
    {
        <div class="alert alert-info d-flex align-items-center gap-3">
            <span class="bi bi-info-circle-fill fs-4"></span>
            <div>Henüz yapı tanımlanmamış. <strong>Yeni Yapı</strong> butonuyla ekleyebilirsiniz.</div>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var s in _structures)
            {
                <div class="col-sm-6 col-xl-4">
                    <div class="structure-card @(s.IsActive ? "" : "opacity-60")" @onclick="() => OpenStructureDetail(s.Id)">
                        @if (!string.IsNullOrEmpty(s.ImageUrl))
                        {
                            <img src="@s.ImageUrl" class="structure-card-img" alt="@s.Name" />
                        }
                        else
                        {
                            <div class="structure-card-img-placeholder">
                                <span>@GetStructureEmoji(s.StructureType)</span>
                            </div>
                        }
                        <div class="structure-card-body">
                            <div class="structure-card-title">@s.Name</div>
                            <div class="structure-card-sub">
                                <span class="bi bi-geo-alt me-1"></span>
                                @s.Province@(string.IsNullOrEmpty(s.District) ? "" : " / " + s.District)
                            </div>
                            <div class="structure-card-badges">
                                <span class="badge" style="background:#6f42c1">@GetStructureLabel(s.StructureType)</span>
                                <span class="badge bg-primary">@s.SensorCount sensör</span>
                                @if (s.IsActive)
                                { <span class="badge bg-success">Aktif</span> }
                                else
                                { <span class="badge bg-secondary">Pasif</span> }
                            </div>
                            <div class="mt-3 d-flex justify-content-end gap-2">
                                @if (_runningStructureIds.Contains(s.Id))
                                {
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => StopStructureSimulationAsync(s.Id)"
                                            @onclick:stopPropagation="true"
                                            disabled="@_stoppingStructureIds.Contains(s.Id)">
                                        @if (_stoppingStructureIds.Contains(s.Id))
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        else
                                        {
                                            <span class="bi bi-stop-fill me-1"></span>
                                        }
                                        Durdur
                                    </button>
                                }
                                <button class="btn btn-sm btn-success"
                                        @onclick="() => StartStructureSimulationAsync(s.Id)"
                                        @onclick:stopPropagation="true"
                                        disabled="@(_startingStructureIds.Contains(s.Id) || _runningStructureIds.Contains(s.Id) || s.SensorCount == 0)"
                                        title="@(s.SensorCount == 0 ? "Sensör tanımlı değil; yapı çalıştırılamaz." : "Yapıyı çalıştır")">
                                    @if (_startingStructureIds.Contains(s.Id))
                                    {
                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                    }
                                    else
                                    {
                                        <span class="bi bi-play-fill me-1"></span>
                                    }
                                    @if (s.SensorCount == 0)
                                    {
                                        <span>Sensör yok</span>
                                    }
                                    else
                                    {
                                        @(_runningStructureIds.Contains(s.Id) ? "Çalışıyor" : "Çalıştır")
                                    }
                                </button>
                                <button class="btn btn-sm btn-outline-warning"
                                        @onclick="() => OpenNodeRedAsync(s.Id, s.Name)"
                                        @onclick:stopPropagation="true"
                                        title="@(string.IsNullOrWhiteSpace(s.NodeRedUrl) ? "Merkez Node-RED Flow Editörü" : $"Flow Editörü: {s.NodeRedUrl}")">
                                    <span class="bi bi-diagram-3 me-1"></span>
                                    @if (string.IsNullOrWhiteSpace(s.NodeRedUrl))
                                    {
                                        <span class="text-muted">Node-RED</span>
                                    }
                                    else
                                    {
                                        <span>Node-RED ✦</span>
                                    }
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@* ══════════════════════════════════════════════════════════════════
   YENİ YAPI OLUŞTURMA — 3 ADIM
   ══════════════════════════════════════════════════════════════════ *@
@if (_showCreateWizard)
{
    <div class="create-structure-panel mb-4">
        <div class="create-panel-header">
            <strong><span class="bi bi-plus-circle me-2"></span>Yeni Yapı Oluştur</strong>
            <button class="btn btn-sm btn-outline-light" @onclick="CancelCreate">İptal</button>
        </div>

        <div class="create-steps">
            <div class="create-step @(_wizardStep >= 1 ? (_wizardStep > 1 ? "done" : "active") : "")">
                <div class="create-step-num">@(_wizardStep > 1 ? "✓" : "1")</div>
                <div>Yapı Tipi</div>
            </div>
            <div class="create-step @(_wizardStep >= 2 ? (_wizardStep > 2 ? "done" : "active") : "")">
                <div class="create-step-num">@(_wizardStep > 2 ? "✓" : "2")</div>
                <div>Bilgiler &amp; Konum</div>
            </div>
            <div class="create-step @(_wizardStep >= 3 ? "active" : "")">
                <div class="create-step-num">3</div>
                <div>Sensör Ekle</div>
            </div>
        </div>

        <div class="p-4">
            @* ADIM 1 — Yapı tipi *@
            @if (_wizardStep == 1)
            {
                <p class="text-muted mb-3">Oluşturmak istediğiniz yapının tipini seçin:</p>
                <div class="structure-type-grid">
                    @foreach (var st in _structureTypes)
                    {
                        <div class="structure-type-card @(st.Key == _newType ? "selected" : "")"
                             @onclick="() => SelectNewType(st.Key)">
                            <span class="type-icon">@st.Value.Emoji</span>
                            <span class="type-label">@st.Value.Label</span>
                        </div>
                    }
                </div>
                <div class="mt-3">
                    <button class="btn btn-primary" disabled="@(_newType == null)"
                            @onclick="GoToStep2">
                        İleri <span class="bi bi-arrow-right ms-1"></span>
                    </button>
                </div>
            }

            @* ADIM 2 — Temel bilgiler *@
            @if (_wizardStep == 2)
            {
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Yapı Adı <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="_newName" placeholder="Örn: Yusufeli Barajı" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Durum</label>
                        <div class="form-check mt-2">
                            <input class="form-check-input" type="checkbox" @bind="_newIsActive" id="chkActive" />
                            <label class="form-check-label" for="chkActive">Aktif</label>
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Açıklama</label>
                        <input class="form-control" @bind="_newDescription" placeholder="Yapı hakkında kısa bir açıklama" />
                    </div>
                    @* ── Konum bilgileri de burada ── *@
                    <div class="col-12"><hr class="my-1" /><small class="text-muted fw-semibold">Konum Bilgileri</small></div>
                    <div class="col-md-4">
                        <label class="form-label">İl <span class="text-danger">*</span></label>
                        <select class="form-select" value="@_newProvince" @onchange="OnNewProvinceChanged">
                            <option value="">-- İl Seçin --</option>
                            @foreach (var p in _provinces)
                            { <option value="@p">@p</option> }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">İlçe</label>
                        <select class="form-select" value="@_newDistrict" @onchange="OnNewDistrictChanged"
                                disabled="@(string.IsNullOrEmpty(_newProvince))">
                            <option value="">-- İlçe Seçin --</option>
                            @foreach (var d in _newDistricts)
                            { <option value="@d">@d</option> }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Adres</label>
                        <input id="address-input" class="form-control" @bind="_newAddress" placeholder="Cadde / mahalle" />
                    </div>
                    @* ── Harita ── *@
                    <div class="col-12">
                        <label class="form-label">
                            <span class="bi bi-map me-1"></span>Konum Seç
                            <small class="text-muted fw-normal"> — Haritaya tıklayın ya da marker'ı sürükleyin</small>
                        </label>
                        <div id="new-map" class="map-container"></div>
                        <div class="row mt-2 g-2">
                            <div class="col-md-4">
                                <label class="form-label small">Enlem</label>
                                <input id="lat-input" type="number" class="form-control form-control-sm" @bind="_newLat" step="0.000001" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small">Boylam</label>
                                <input id="lng-input" type="number" class="form-control form-control-sm" @bind="_newLng" step="0.000001" />
                            </div>
                        </div>
                    </div>
                    @* ── Node-RED ── *@
                    <div class="col-12"><hr class="my-1" /><small class="text-muted fw-semibold">Node-RED Entegrasyonu</small></div>
                    <div class="col-12">
                        <label class="form-label">
                            <span class="bi bi-diagram-3 me-1"></span>Node-RED URL
                            @if (!string.IsNullOrWhiteSpace(_newNodeRedUrl))
                            {
                                <span class="badge bg-success ms-2" style="font-size:0.7rem">Otomatik atandı</span>
                            }
                            else
                            {
                                <small class="text-muted fw-normal"> — Boş bırakılırsa ortak instance kullanılır</small>
                            }
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <span class="bi bi-diagram-3@(!string.IsNullOrWhiteSpace(_newNodeRedUrl) ? "-fill text-success" : " text-muted")"></span>
                            </span>
                            <input class="form-control @(!string.IsNullOrWhiteSpace(_newNodeRedUrl) ? "bg-light" : "")"
                                   @bind="_newNodeRedUrl"
                                   readonly="@(!string.IsNullOrWhiteSpace(Configuration[$"NodeRed:PerStructureUrls:{_newType}"]))"
                                   placeholder="http://nodered-yapi-adi:1880 (opsiyonel)" />
                            @if (!string.IsNullOrWhiteSpace(_newNodeRedUrl))
                            {
                                <button class="btn btn-outline-secondary" type="button"
                                        title="Temizle — ortak instance kullanılır"
                                        @onclick="() => _newNodeRedUrl = string.Empty">
                                    <span class="bi bi-x-lg"></span>
                                </button>
                            }
                        </div>
                        <div class="form-text">
                            @if (!string.IsNullOrWhiteSpace(_newNodeRedUrl))
                            {
                                <span class="text-success"><span class="bi bi-check-circle me-1"></span>Bu yapı tipi için Node-RED instance'ı otomatik atandı.</span>
                            }
                            else
                            {
                                <span>Yapı tipini seçince otomatik dolar. Kubernetes'te özel pod varsa URL'i girin; Docker Compose'da <code>nodered-{yapı-slug}</code> kullanın.</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="mt-3 d-flex gap-2">
                    <button class="btn btn-outline-secondary" @onclick="BackFromStep2">
                        <span class="bi bi-arrow-left me-1"></span> Geri
                    </button>
                    <button class="btn btn-primary" disabled="@(string.IsNullOrWhiteSpace(_newName) || string.IsNullOrEmpty(_newProvince))"
                            @onclick="GoToSensorStep">
                        İleri — Sensör Ekle <span class="bi bi-arrow-right ms-1"></span>
                    </button>
                    <button class="btn btn-success ms-auto" disabled="@(string.IsNullOrWhiteSpace(_newName) || string.IsNullOrEmpty(_newProvince) || _isSaving)"
                            @onclick="SaveNewStructureAsync">
                        @if (_isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <span class="bi bi-check-lg me-1"></span> Kaydet (Sensörsüz)
                    </button>
                </div>
            }

            @* ADIM 3 — Yapı resmi üzerinde sensör ekleme *@
            @if (_wizardStep == 3)
            {
                <div class="mb-3 d-flex align-items-center gap-3">
                    <div>
                        <strong>@_newName</strong>
                        <span class="badge ms-2" style="background:#6f42c1">@(_newType.HasValue ? GetStructureLabel(_newType.Value) : "")</span>
                        @if (!string.IsNullOrEmpty(_newProvince))
                        { <span class="badge bg-info ms-1">@_newProvince@(string.IsNullOrEmpty(_newDistrict) ? "" : " / " + _newDistrict)</span> }
                    </div>
                    <div class="ms-auto d-flex gap-2">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="BackFromStep3">
                            <span class="bi bi-arrow-left me-1"></span> Geri
                        </button>
                        <button class="btn btn-success" @onclick="() => _showSaveConfirm = true" disabled="@_isSaving">
                            @if (_isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            <span class="bi bi-check-lg me-1"></span> Tamamla &amp; Kaydet
                        </button>
                    </div>
                </div>
                <div class="alert alert-info d-flex align-items-center gap-2 py-2 small mb-2">
                    <span class="bi bi-cursor-fill text-primary"></span>
                    Resme tıklayarak sensör konumlandırın. İstediğiniz kadar sensör ekleyebilirsiniz, daha sonra da eklenebilir.
                </div>
                @* Yapı resmi — JS tarafından doldurulur (initStructureImage), burada sadece container *@
                <div class="wizard-image-wrapper" id="wizard-image">
                    @* JS initStructureImage() bu div'in içini doldurur *@
                </div>
                @* Eklenen sensörler listesi *@
                @if (_newStructureSensors.Any())
                {
                    <div class="mt-3">
                        <h6 class="fw-semibold mb-2"><span class="bi bi-cpu me-1"></span>Eklenen Sensörler (@_newStructureSensors.Count)</h6>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered mb-0">
                                <thead class="table-dark">
                                    <tr><th>#</th><th>Tip</th><th>Ad</th><th>Device ID</th><th>Topic</th><th>Metrikler</th><th>Telemetri</th><th>X/Y</th><th></th></tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < _newStructureSensors.Count; i++)
                                    {
                                        var idx = i;
                                        var s = _newStructureSensors[idx];
                                        var icon = _sensorTypeInfos.TryGetValue(s.SensorType.ToString(), out var ti) ? ti.Emoji : "🔘";
                                        <tr>
                                            <td>@(idx + 1)</td>
                                            <td><span title="@s.SensorType">@icon</span></td>
                                            <td>@s.Name</td>
                                            <td><code style="font-size:0.75rem">@s.DeviceId</code></td>
                                            <td><small class="font-monospace">@s.Topic</small></td>
                                            <td>
                                                @{var wMetrics = !string.IsNullOrWhiteSpace(s.Metrics) ? s.Metrics : s.Description;}
                                                @foreach (var m in (wMetrics ?? string.Empty).Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries))
                                                {
                                                    <span class="badge bg-info text-dark me-1" style="font-size:0.65rem">@m</span>
                                                }
                                            </td>
                                            <td><small class="text-muted">@(s.TelemetryIntervalMs / 1000) sn / @(s.TelemetryBatchSize) ölçüm</small></td>
                                            <td><small>@(s.ImagePositionX?.ToString("F1") ?? "-"), @(s.ImagePositionY?.ToString("F1") ?? "-")</small></td>
                                            <td>
                                                <button class="btn btn-outline-danger py-0 px-1" style="font-size:0.7rem;line-height:1.4"
                                                        @onclick="() => RemoveWizardSensor(idx)">✕</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
}

@* ══════════════════════════════════════════════════════════════════
   YAPI DETAY — Görsel + Sensör Overlay
   ══════════════════════════════════════════════════════════════════ *@
@if (_editingStructure != null)
{
    <div class="structure-detail-panel mb-4">
        <div class="structure-detail-header">
            <div class="d-flex align-items-center gap-2 overflow-hidden">
                <span style="font-size:1.4rem">@GetStructureEmoji(_editingStructure.StructureType)</span>
                <div class="overflow-hidden">
                    <h5 class="mb-0 text-truncate">@_editingStructure.Name</h5>
                    <small class="text-white-50">
                        @_editingStructure.Province
                        @(string.IsNullOrEmpty(_editingStructure.District) ? "" : " / " + _editingStructure.District)
                        · @GetStructureLabel(_editingStructure.StructureType)
                    </small>
                </div>
            </div>
            <div class="d-flex gap-2 flex-shrink-0">
                <button class="btn btn-sm btn-outline-light" @onclick="EditStructureInfo" title="Bilgileri düzenle">
                    <span class="bi bi-pencil me-1"></span>Düzenle
                </button>
                <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(_editingStructure.Id)" title="Sil">
                    <span class="bi bi-trash"></span>
                </button>
                <button class="btn btn-sm btn-outline-light" @onclick="CloseDetail">
                    <span class="bi bi-x-lg"></span>
                </button>
            </div>
        </div>

        @* ── Görsel Overlay — JS initStructureImage() doldurur ── *@
        <div class="structure-image-wrapper" id="structure-image">
            @* JS tarafından doldurulur *@
        </div>
        <div class="structure-image-click-hint">
            <span class="bi bi-plus-circle me-1"></span>Resme tıklayarak sensör ekleyin
        </div>

        @* ── Alt bilgi + Kayıtlı Sensörler ── *@
        <div class="structure-detail-info">
            @if (!string.IsNullOrEmpty(_editingStructure.Description))
            {
                <span><span class="bi bi-info-circle me-1 text-muted"></span>@_editingStructure.Description</span>
            }
            @if (_editingStructure.Latitude.HasValue)
            {
                <span><span class="bi bi-crosshair me-1 text-muted"></span>
                    @_editingStructure.Latitude.Value.ToString("F5"), @_editingStructure.Longitude!.Value.ToString("F5")
                </span>
            }
            <span><span class="bi bi-cpu me-1 text-muted"></span>@(_editingStructure.Sensors?.Count ?? 0) sensör</span>
            <span class="ms-auto">
                <button class="btn btn-sm btn-outline-secondary" @onclick="RefreshMarkersAsync">
                    <span class="bi bi-arrow-clockwise me-1"></span>Yenile
                </button>
            </span>
        </div>

        @* ── Kayıtlı Sensör Listesi ── *@
        @if (_editingStructure.Sensors?.Any() == true)
        {
            <div class="px-3 pb-3">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0" style="font-size:0.83rem">
                        <thead class="table-light">
                            <tr>
                                <th style="width:32px"></th>
                                <th>Sensör Adı</th>
                                <th>Tip</th>
                                <th>Device ID</th>
                                <th>Topic</th>
                                <th>Metrikler</th>
                                <th style="width:40px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ss in _editingStructure.Sensors)
                            {
                                var icon = GetSensorEmoji(ss.SensorType);
                                <tr>
                                    <td class="text-center">@icon</td>
                                    <td>@ss.Name</td>
                                    <td><span class="badge bg-secondary">@ss.SensorType</span></td>
                                    <td><code style="font-size:0.75rem">@ss.DeviceId</code></td>
                                    <td><small class="font-monospace" title="@ss.Topic" style="font-size:0.72rem">@(ss.Topic.Length > 32 ? ss.Topic[..30] + "…" : ss.Topic)</small></td>
                                    <td>
                                        @{
                                            // Metrics field (new) takes priority; fall back to Description (legacy)
                                            var metricsCsv = !string.IsNullOrWhiteSpace(ss.Metrics) ? ss.Metrics : ss.Description;
                                        }
                                        @if (!string.IsNullOrEmpty(metricsCsv))
                                        {
                                            @foreach (var m in metricsCsv.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                            {
                                                <span class="badge bg-info text-dark me-1" style="font-size:0.65rem">@m</span>
                                            }
                                        }
                                        else
                                        {
                                            <small class="text-muted">-</small>
                                        }
                                    </td>
                                    <td>
                                        <button class="btn btn-outline-danger btn-sm py-0 px-1"
                                                style="font-size:0.7rem;line-height:1.5"
                                                title="Sensörü sil"
                                                @onclick="() => RemoveSensorFromStructureAsync(ss.SensorId)">
                                            <span class="bi bi-trash"></span>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
}

@* ══════════════════════════════════════════════════════════════════
   SENSÖR EKLEME POPUP
   ══════════════════════════════════════════════════════════════════ *@
@if (_showSensorPopup)
{
    <div class="popup-overlay" @onclick="CloseSensorPopup"></div>
    <div class="sensor-add-popup">
        <div class="sensor-add-popup-header">
            <span><span class="bi bi-plus-circle me-2"></span>Yeni Sensör Ekle</span>
            <button style="background:none;border:none;color:rgba(255,255,255,0.8);font-size:20px;cursor:pointer;padding:0 4px"
                    @onclick="CloseSensorPopup">&times;</button>
        </div>
        
        @* ── Sekme Seçimi ── *@
        <div style="display:flex; gap:0; border-bottom: 1px solid #dee2e6; background:#f8f9fa; padding: 0 0.75rem;">
            <button class="nav-tab @(_addSensorTab == "manual" ? "active" : "")"
                    @onclick='() => { _addSensorTab = "manual"; StateHasChanged(); }'
                    style="background:none; border:none; border-bottom:3px solid transparent; padding:0.75rem 1rem; cursor:pointer; color: @(_addSensorTab == "manual" ? "#0d6efd" : "#6c757d"); border-bottom-color: @(_addSensorTab == "manual" ? "#0d6efd" : "transparent"); font-weight: @(_addSensorTab == "manual" ? "600" : "400");">
                <span class="bi bi-hand-index me-1"></span>Manuel Ekle
            </button>
            <button class="nav-tab @(_addSensorTab == "tcp" ? "active" : "")"
                    @onclick='() => { _addSensorTab = "tcp"; StateHasChanged(); }'
                    style="background:none; border:none; border-bottom:3px solid transparent; padding:0.75rem 1rem; cursor:pointer; color: @(_addSensorTab == "tcp" ? "#0d6efd" : "#6c757d"); border-bottom-color: @(_addSensorTab == "tcp" ? "#0d6efd" : "transparent"); font-weight: @(_addSensorTab == "tcp" ? "600" : "400");">
                <span class="bi bi-diagram-3 me-1"></span>TCP/IP ile Ekle
            </button>
        </div>
        <div class="sensor-add-popup-body">
            @* ── TAB 1: Manuel Ekle ── *@
            @if (_addSensorTab == "manual")
            {
                <div class="alert alert-light border small d-flex align-items-center gap-2 mb-3 py-2">
                    <span class="bi bi-crosshair text-primary"></span>
                    Konum: X=@(_pendingPos?.x.ToString("F1") ?? "—"), Y=@(_pendingPos?.y.ToString("F1") ?? "—")
                </div>

                @* Sensör tipi seçici *@
                <label class="form-label fw-semibold mb-2">Sensör Tipi</label>
                <div class="sensor-type-selector mb-3">
                    @foreach (var st in _sensorTypeInfos)
                    {
                        <div class="sensor-type-btn @(_sensorFormType == st.Key ? "active" : "")"
                             @onclick="() => OnSensorTypeSelected(st.Key)">
                            <span class="stype-icon">@st.Value.Emoji</span>
                            @st.Value.Label
                        </div>
                    }
                </div>

                @* Metrik seçimi (çoklu) *@
                <label class="form-label fw-semibold mb-1">
                    Metrikler
                    <small class="text-muted fw-normal"> — bu sensörün yayınlayacağı veri tipleri</small>
                </label>
                <div class="d-flex flex-wrap gap-2 mb-3">
                    @foreach (var m in _allMetrics)
                    {
                        var selected = _sensorFormMetrics.Contains(m.Key);
                        <button type="button"
                                class="btn btn-sm @(selected ? "btn-primary" : "btn-outline-secondary")"
                                @onclick="() => ToggleMetric(m.Key)">
                            @m.Value.Emoji @m.Value.Label
                            @if (selected) { <span class="bi bi-check ms-1"></span> }
                        </button>
                    }
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Sensör Adı <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="_sensorFormName" placeholder="Örn: Kuzey Ayak Titreşim" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Device ID <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="_sensorFormDeviceId" placeholder="sensor-001" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">
                            MQTT Topic
                            <small class="text-muted fw-normal"> — tip seçince otomatik dolar</small>
                        </label>
                        <input class="form-control" @bind="_sensorFormTopic" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Birim</label>
                        <input class="form-control" @bind="_sensorFormUnit" placeholder="mm/s, °C…" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Protokol</label>
                        <select class="form-select" @bind="_sensorFormProtocol">
                            <option value="MQTT">MQTT</option>
                            <option value="Modbus">Modbus</option>
                            <option value="HTTP">HTTP</option>
                            <option value="Serial">Seri Port</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">
                            Ölçüm Aralığı
                            <small class="text-muted fw-normal d-block" style="font-size:0.72rem">
                                Kaç saniyede bir pencere açılsın
                            </small>
                        </label>
                        <select class="form-select" @bind="_sensorFormTelemetryIntervalSec">
                            <option value="1">1 sn</option>
                            <option value="2">2 sn</option>
                            <option value="5">5 sn</option>
                            <option value="10">10 sn</option>
                            <option value="30">30 sn</option>
                            <option value="60">1 dk</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">
                            Ölçüm / Pencere
                            <small class="text-muted fw-normal d-block" style="font-size:0.72rem">
                                Cihaz başı kaç ölçüm gönderilsin
                            </small>
                        </label>
                        <input type="number" class="form-control"
                               min="1" max="1000" step="1"
                               placeholder="Örn: 200"
                               @bind="_sensorFormTelemetryBatchSize" />
                        @if (_sensorFormTelemetryBatchSize > 1)
                        {
                            <small class="text-muted">
                                ≈ @Math.Round(_sensorFormTelemetryBatchSize / (double)_sensorFormTelemetryIntervalSec, 1) ölçüm/sn
                            </small>
                        }
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Konum Etiketi</label>
                        <input class="form-control" @bind="_sensorFormLabel" placeholder="Örn: Kuzey Ayak" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Açıklama</label>
                        <input class="form-control" @bind="_sensorFormDescription" />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(_saveError))
                {
                    <div class="alert alert-danger mt-2 py-2 small">@_saveError</div>
                }

                <div class="mt-3 d-flex gap-2">
                    <button class="btn btn-success" disabled="@(string.IsNullOrWhiteSpace(_sensorFormName) || string.IsNullOrWhiteSpace(_sensorFormDeviceId) || _isSaving)"
                            @onclick="SaveSensorAsync">
                        @if (_isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <span class="bi bi-check-lg me-1"></span>
                        @(_isWizardSensorMode ? "Listeye Ekle" : "DB'ye Kaydet")
                    </button>
                    <button class="btn btn-secondary" @onclick="CloseSensorPopup">İptal</button>
                </div>
            }

            @* ── TAB 2: TCP/IP ile Ekle ── *@
            @if (_addSensorTab == "tcp")
            {
                <p class="text-muted mb-3 small">TCP/IP üzerinden yeni sensör bağlantısı ekleyin.</p>
                
                <div class="alert alert-light border small d-flex align-items-center gap-2 mb-3 py-2">
                    <span class="bi bi-crosshair text-primary"></span>
                    Konum: X=@(_pendingPos?.x.ToString("F1") ?? "—"), Y=@(_pendingPos?.y.ToString("F1") ?? "—")
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Sensör Adı <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="_tcpSensorName" placeholder="Örn: Ana Transformer" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Sensör Tipi <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="_tcpSensorType">
                            <option value="">— Seçiniz —</option>
                            @foreach (var sensorType in Enum.GetValues<SensorType>())
                            {
                                <option value="@sensorType.ToString()">@sensorType</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="row g-3 mt-2">
                    <div class="col-md-6">
                        <label class="form-label">IP Adresi <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="_tcpIpAddress" placeholder="192.168.1.100" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Port <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" @bind="_tcpPort" placeholder="502" min="1" max="65535" />
                    </div>
                </div>

                <div class="row g-3 mt-2">
                    <div class="col-md-6">
                        <label class="form-label">Protocol</label>
                        <select class="form-select" @bind="_tcpProtocol">
                            <option value="TCP">TCP</option>
                            <option value="Modbus">Modbus TCP</option>
                            <option value="OPC-UA">OPC UA</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Device ID</label>
                        <input type="text" class="form-control" @bind="_tcpDeviceId" placeholder="Örn: DEV001" />
                    </div>
                </div>

                <div class="row g-3 mt-2">
                    <div class="col-md-6">
                        <label class="form-label">Timeout (ms)</label>
                        <input type="number" class="form-control" @bind="_tcpTimeout" min="100" max="60000" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Polling Interval (ms)</label>
                        <input type="number" class="form-control" @bind="_tcpPollInterval" min="100" max="60000" />
                    </div>
                </div>

                <div class="mt-3">
                    <label class="form-label">Açıklama</label>
                    <textarea class="form-control" @bind="_tcpDescription" rows="2" placeholder="İsteğe bağlı notlar..."></textarea>
                </div>

                @if (!string.IsNullOrEmpty(_saveError))
                {
                    <div class="alert alert-danger mt-2 py-2 small">@_saveError</div>
                }

                <div class="mt-3 d-flex gap-2">
                    <button class="btn btn-success" disabled="@(string.IsNullOrWhiteSpace(_tcpSensorName) || string.IsNullOrWhiteSpace(_tcpSensorType) || string.IsNullOrWhiteSpace(_tcpIpAddress) || !_tcpPort.HasValue || _isSaving)"
                            @onclick="SaveTcpSensorAsync">
                        @if (_isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <span class="bi bi-check-lg me-1"></span>TCP/IP Sensörünü Ekle
                    </button>
                    <button class="btn btn-secondary" @onclick="CloseSensorPopup">İptal</button>
                </div>
            }
        </div>
    </div>
}

@* ══════════════════════════════════════════════════════════════════
   YAPI BİLGİ DÜZENLEME POPUP
   ══════════════════════════════════════════════════════════════════ *@
@if (_showEditPopup && _editingStructure != null)
{
    <div class="popup-overlay" @onclick="CloseEditPopup"></div>
    <div class="sensor-add-popup">
        <div class="sensor-add-popup-header edit-popup-header">
            <span><span class="bi bi-pencil me-2"></span>Yapı Bilgilerini Düzenle</span>
            <button style="background:none;border:none;color:rgba(255,255,255,0.8);font-size:20px;cursor:pointer;padding:0 4px"
                    @onclick="CloseEditPopup">&times;</button>
        </div>
        <div class="sensor-add-popup-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Yapı Adı</label>
                    <input class="form-control" @bind="_editName" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Yapı Tipi</label>
                    <select class="form-select" @bind="_editType">
                        @foreach (var st in _structureTypes)
                        {
                            <option value="@st.Key">@st.Value.Label</option>
                        }
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label">Açıklama</label>
                    <input class="form-control" @bind="_editDescription" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">İl</label>
                    <select class="form-select" value="@_editProvince" @onchange="OnEditProvinceChanged">
                        <option value="">-- Seçin --</option>
                        @foreach (var p in _provinces)
                        { <option value="@p">@p</option> }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">İlçe</label>
                    <select class="form-select" @bind="_editDistrict">
                        <option value="">-- Seçin --</option>
                        @foreach (var d in _editDistricts)
                        { <option value="@d">@d</option> }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Adres</label>
                    <input class="form-control" @bind="_editAddress" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Durum</label>
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" @bind="_editIsActive" id="chkEditActive" />
                        <label class="form-check-label" for="chkEditActive">Aktif</label>
                    </div>
                </div>
                <div class="col-12">
                    <label class="form-label">
                        <span class="bi bi-diagram-3 me-1"></span>Node-RED URL
                        <small class="text-muted fw-normal"> — Boş bırakılırsa ortak instance kullanılır</small>
                    </label>
                    <input class="form-control" @bind="_editNodeRedUrl"
                           placeholder="http://nodered-yapi-adi:1880 (opsiyonel)" />
                </div>
            </div>
            <div class="mt-3 d-flex gap-2">
                <button class="btn btn-success" @onclick="SaveEditAsync" disabled="@_isSaving">
                    @if (_isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <span class="bi bi-check-lg me-1"></span> Kaydet
                </button>
                <button class="btn btn-secondary" @onclick="CloseEditPopup">İptal</button>
            </div>
        </div>
    </div>
}

@* Kaydet onay modalı (Wizard adım 3) *@
@if (_showSaveConfirm)
{
    <div class="popup-overlay" @onclick="() => _showSaveConfirm = false"></div>
    <div class="sensor-add-popup" style="max-width:480px">
        <div class="sensor-add-popup-header" style="background:linear-gradient(90deg,#198754,#0f6241)">
            <span><span class="bi bi-save me-2"></span>Yapıyı Kaydet</span>
            <button style="background:none;border:none;color:#fff;font-size:20px;cursor:pointer" @onclick="() => _showSaveConfirm = false">&times;</button>
        </div>
        <div class="sensor-add-popup-body">
            <p class="mb-3">
                <strong>@_newName</strong> yapısı ve
                <strong>@_newStructureSensors.Count</strong> sensör birlikte veritabanına kaydedilecek.
            </p>
            <div class="table-responsive mb-3" style="max-height:200px;overflow-y:auto">
                <table class="table table-sm table-bordered mb-0 small">
                    <thead class="table-secondary">
                        <tr><th>Sensör</th><th>Tip</th><th>Topic</th><th>Metrikler</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var s in _newStructureSensors)
                        {
                            <tr>
                                <td>@s.Name</td>
                                <td><span class="badge bg-secondary">@s.SensorType</span></td>
                                <td><small class="font-monospace">@(s.Topic.Length > 30 ? s.Topic[..28] + "…" : s.Topic)</small></td>
                                <td><small class="text-muted">@(string.IsNullOrEmpty(s.Metrics) ? "-" : s.Metrics)</small></td>
                            </tr>
                        }
                        @if (!_newStructureSensors.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted">Sensör eklenmedi (sonradan eklenebilir)</td></tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (!string.IsNullOrEmpty(_saveError))
            {
                <div class="alert alert-danger py-2 small">@_saveError</div>
            }
            <div class="d-flex gap-2">
                <button class="btn btn-success" @onclick="ConfirmedSaveAsync" disabled="@_isSaving">
                    @if (_isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    <span class="bi bi-check-lg me-1"></span> Evet, Kaydet
                </button>
                <button class="btn btn-secondary" @onclick="() => _showSaveConfirm = false">İptal</button>
            </div>
        </div>
    </div>
}

@* Silme onay modalı *@
@if (_deletingId.HasValue)
{
    <div class="popup-overlay" @onclick="() => _deletingId = null"></div>
    <div class="sensor-add-popup" style="max-width:400px">
        <div class="sensor-add-popup-header" style="background:linear-gradient(90deg,#dc3545,#a71d2a)">
            <span><span class="bi bi-trash me-2"></span>Yapıyı Sil</span>
            <button style="background:none;border:none;color:#fff;font-size:20px;cursor:pointer" @onclick="() => _deletingId = null">&times;</button>
        </div>
        <div class="sensor-add-popup-body">
            <p class="mb-3">Bu yapı ve tüm sensör bağlantıları kalıcı olarak silinecek. Devam etmek istiyor musunuz?</p>
            <div class="d-flex gap-2">
                <button class="btn btn-danger" @onclick="DoDeleteAsync" disabled="@_isSaving">
                    @if (_isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Evet, Sil
                </button>
                <button class="btn btn-secondary" @onclick="() => _deletingId = null">İptal</button>
            </div>
        </div>
    </div>
}

@code {
    // ── State ────────────────────────────────────────────────────────────────
    private List<Structure>? _structures;
