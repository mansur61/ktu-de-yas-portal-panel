@page "/workspaces"
@rendermode InteractiveServer
@using KtuDeYasPortal.Panel.Infrastructure.Persistence
@inject WorkspaceUseCases WorkspaceUC
@inject IJSRuntime JS

<PageTitle>Workspace Yönetimi</PageTitle>

@* ── Bildirim bantları ──────────────────────────────────────────────────── *@
@if (!string.IsNullOrWhiteSpace(_successMsg))
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-3 py-2 alert-dismissible">
        <span class="bi bi-check-circle-fill"></span>
        <div>@_successMsg</div>
        <button type="button" class="btn-close ms-auto" @onclick="() => _successMsg = null"></button>
    </div>
}
@if (!string.IsNullOrWhiteSpace(_errorMsg))
{
    <div class="alert alert-danger d-flex align-items-center gap-2 mb-3 py-2 alert-dismissible">
        <span class="bi bi-exclamation-triangle-fill"></span>
        <div>@_errorMsg</div>
        <button type="button" class="btn-close ms-auto" @onclick="() => _errorMsg = null"></button>
    </div>
}

@* ── Başlık + Yeni Workspace butonu ────────────────────────────────────── *@
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold">
            <span class="bi bi-box-seam me-2 text-primary"></span>Workspace Yönetimi
        </h4>
        <small class="text-muted">
            Araştırmacı Node-RED container'ları — geçici, izole, silinebilir
        </small>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary btn-sm" @onclick="RefreshAsync" disabled="@_loading">
            <span class="bi bi-arrow-clockwise me-1 @(_loading ? "spin" : "")"></span>Yenile
        </button>
        <button class="btn btn-primary" @onclick="OpenCreatePanel">
            <span class="bi bi-plus-lg me-1"></span>Yeni Workspace
        </button>
    </div>
</div>

@* ═══════════════════════════════════════════════════════════════════════════
   WORKSPACE OLUŞTURMA PANELİ (sağ drawer)
   ═══════════════════════════════════════════════════════════════════════════ *@
@if (_showCreate)
{
    <div class="ws-drawer-backdrop" @onclick="CloseCreatePanel"></div>
    <div class="ws-drawer">
        <div class="ws-drawer-header">
            <h5 class="mb-0 fw-bold">
                <span class="bi bi-plus-circle me-2 text-primary"></span>Yeni Workspace
            </h5>
            <button class="btn-close" @onclick="CloseCreatePanel"></button>
        </div>

        <div class="ws-drawer-body">
            @* Adım 1 — Yapı seç *@
            <div class="mb-4">
                <label class="form-label fw-semibold">
                    <span class="bi bi-building me-1"></span>Yapı Seç
                    <span class="text-danger">*</span>
                </label>
                @if (_structures is null)
                {
                    <div class="text-muted small">
                        <span class="spinner-border spinner-border-sm me-1"></span>Yapılar yükleniyor…
                    </div>
                }
                else if (_structures.Count == 0)
                {
                    <div class="alert alert-warning py-2 small">
                        <span class="bi bi-exclamation-triangle me-1"></span>
                        Henüz kayıtlı yapı yok. Önce Yapı Yönetimi'nden yapı ekleyin.
                    </div>
                }
                else
                {
                    <select class="form-select" @onchange="OnStructureSelected">
                        <option value="">— Yapı seçin —</option>
                        @foreach (var s in _structures)
                        {
                            <option value="@s.Id">@s.Name (@s.Province)</option>
                        }
                    </select>
                }
            </div>

            @* Adım 2 — Yapı bilgileri (seçim sonrası) *@
            @if (_selectedStructure is not null)
            {
                <div class="ws-info-card mb-4">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <span class="badge bg-secondary">@_selectedStructure.StructureType</span>
                        <span class="fw-semibold">@_selectedStructure.Name</span>
                    </div>
                    <div class="small text-muted mb-1">
                        <span class="bi bi-geo-alt me-1"></span>@_selectedStructure.Province @_selectedStructure.District
                    </div>
                    <div class="small">
                        <span class="fw-semibold me-1">Sensör:</span>@_selectedStructure.SensorCount adet
                    </div>
                </div>

                @* Adım 3 — Workspace adı *@
                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        <span class="bi bi-tag me-1"></span>Workspace Adı
                        <span class="text-danger">*</span>
                    </label>
                    <input type="text"
                           class="form-control @(_nameError || _nameInvalidTurkish ? "is-invalid" : "")"
                           placeholder="Örn: Titreşim Analizi, AI Test"
                           @bind="_workspaceName"
                           @bind:event="oninput"
                           maxlength="50" />
                    @if (_nameError)
                    {
                        <div class="invalid-feedback">Workspace adı boş olamaz (en az 3 karakter).</div>
                    }
                    else if (_nameInvalidTurkish)
                    {
                        <div class="invalid-feedback">Workspace adı Türkçe karakter içeremez.</div>
                    }
                    <div class="form-text text-muted">
                        Container adında kullanılır. Türkçe karakter kullanılmaz.
                    </div>
                </div>

                @* Adım 4 — Topic Scope önizleme *@
                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        <span class="bi bi-funnel me-1"></span>Topic Kapsam (Otomatik)
                    </label>
                    <div class="ws-scope-badge">
                        <span class="bi bi-lock-fill me-1 text-warning"></span>
                        <code>@WorkspaceUC.PreviewTopicScope(_selectedStructure)</code>
                    </div>
                    <div class="form-text text-muted">
                        Workspace sadece bu kapsamdaki Kafka mesajlarına erişebilir.
                        Panel tarafından belirlenir, araştırmacı değiştiremez.
                    </div>
                </div>
            }
        </div>

        <div class="ws-drawer-footer">
            <button class="btn btn-outline-secondary" @onclick="CloseCreatePanel">İptal</button>
            <button class="btn btn-primary"
                    @onclick="CreateWorkspaceAsync"
                    disabled="@(_creating || _selectedStructure is null)">
                @if (_creating)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                    <span>Oluşturuluyor…</span>
                }
                else
                {
                    <span class="bi bi-play-fill me-1"></span>
                    <span>Workspace Başlat</span>
                }
            </button>
        </div>
    </div>
}

@* ═══════════════════════════════════════════════════════════════════════════
   LOG MODALI
   ═══════════════════════════════════════════════════════════════════════════ *@
@if (_logContainerId is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.55)">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title fw-bold">
                        <span class="bi bi-terminal me-1"></span>Workspace Logları
                        <small class="text-muted ms-2 fw-normal">@_logContainerName</small>
                    </h6>
                    <button class="btn-close" @onclick="CloseLogModal"></button>
                </div>
                <div class="modal-body p-0">
                    @if (_logLoading)
                    {
                        <div class="text-center py-4">
                            <span class="spinner-border text-primary"></span>
                        </div>
                    }
                    else
                    {
                        <pre class="ws-log-pre">@_logContent</pre>
                    }
                </div>
                <div class="modal-footer py-2">
                    <button class="btn btn-outline-secondary btn-sm"
                            @onclick="() => LoadLogsAsync(_logContainerId!)">
                        <span class="bi bi-arrow-clockwise me-1"></span>Yenile
                    </button>
                    <button class="btn btn-secondary btn-sm" @onclick="CloseLogModal">Kapat</button>
                </div>
            </div>
        </div>
    </div>
}

@* ═══════════════════════════════════════════════════════════════════════════
   WORKSPACE LİSTESİ
   ═══════════════════════════════════════════════════════════════════════════ *@
@if (_loading && (_workspaces is null || _workspaces.Count == 0))
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2 text-muted">Workspace'ler yükleniyor…</p>
    </div>
}
else if (_workspaces is not null && _workspaces.Count == 0)
{
    <div class="ws-empty-state">
        <span class="bi bi-box fs-1 text-muted d-block mb-3"></span>
        <p class="text-muted mb-1">Henüz aktif workspace yok.</p>
        <p class="text-muted small">
            <strong>Yeni Workspace</strong> butonuyla bir yapı seçip araştırma container'ı başlatabilirsiniz.
        </p>
    </div>
}
else if (_workspaces is not null)
{
    <div class="row g-3">
        @foreach (var ws in _workspaces)
        {
            <div class="col-md-6 col-xl-4">
                <div class="ws-card @(ws.Status == "running" ? "ws-card-running" : "ws-card-stopped")">

                    @* Başlık *@
                    <div class="ws-card-header">
                        <div>
                            <div class="ws-card-title">@ws.WorkspaceName</div>
                            <div class="ws-card-sub text-muted small">@ws.ContainerName</div>
                        </div>
                        <span class="badge @(ws.Status == "running" ? "bg-success" : "bg-secondary")">
                            @(ws.Status == "running" ? "Çalışıyor" : ws.Status)
                        </span>
                    </div>

                    @* Bilgiler *@
                    <div class="ws-card-info">
                        <div class="ws-info-row">
                            <span class="bi bi-building me-1 text-muted"></span>
                            <span class="text-muted small">@ws.StructureSlug</span>
                        </div>
                        <div class="ws-info-row">
                            <span class="bi bi-funnel me-1 text-muted"></span>
                            <code class="small">@ws.TopicScope</code>
                        </div>
                        <div class="ws-info-row">
                            <span class="bi bi-hdd-network me-1 text-muted"></span>
                            <span class="text-muted small">Port: @ws.HostPort</span>
                        </div>
                        <div class="ws-info-row">
                            <span class="bi bi-clock me-1 text-muted"></span>
                            <span class="text-muted small">
                                @ws.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                            </span>
                        </div>
                    </div>

                    @* Aksiyonlar *@
                    <div class="ws-card-actions">
                        @if (ws.Status == "running" && !string.IsNullOrEmpty(ws.EditorUrl))
                        {
                            <a href="@ws.EditorUrl" target="_blank"
                               class="btn btn-sm btn-outline-primary">
                                <span class="bi bi-box-arrow-up-right me-1"></span>Editör
                            </a>
                            <a href="@ws.DashboardUrl" target="_blank"
                               class="btn btn-sm btn-outline-info">
                                <span class="bi bi-speedometer2 me-1"></span>Dashboard
                            </a>
                        }
                        <button class="btn btn-sm btn-outline-secondary"
                                @onclick="() => OpenLogModal(ws)">
                            <span class="bi bi-terminal me-1"></span>Log
                        </button>
                        <button class="btn btn-sm btn-outline-warning"
                                @onclick="() => RestartWorkspaceAsync(ws.ContainerId)"
                                disabled="@(_actionId == ws.ContainerId)">
                            <span class="bi bi-arrow-repeat me-1"></span>Yeniden Başlat
                        </button>
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => DeleteWorkspaceAsync(ws.ContainerId, ws.WorkspaceName)"
                                disabled="@(_actionId == ws.ContainerId)">
                            @if (_actionId == ws.ContainerId)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            else
                            {
                                <span class="bi bi-trash me-1"></span>
                            }
                            Sil
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@* ─── Stiller ──────────────────────────────────────────────────────────────── *@
<style>
    /* Drawer */
    .ws-drawer-backdrop {
        position: fixed; inset: 0; background: rgba(0,0,0,.4); z-index: 1040;
    }
    .ws-drawer {
        position: fixed; top: 0; right: 0; bottom: 0; width: 420px;
        background: #fff; box-shadow: -4px 0 24px rgba(0,0,0,.18);
        z-index: 1050; display: flex; flex-direction: column;
    }
    .ws-drawer-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 1rem 1.25rem; border-bottom: 1px solid #dee2e6;
    }
    .ws-drawer-body { flex: 1; overflow-y: auto; padding: 1.25rem; }
    .ws-drawer-footer {
        display: flex; gap: .5rem; justify-content: flex-end;
        padding: 1rem 1.25rem; border-top: 1px solid #dee2e6;
    }

    /* Bilgi kartı (yapı seçimi sonrası) */
    .ws-info-card {
        background: #f0f4ff; border: 1px solid #c5d3f7;
        border-radius: .5rem; padding: .75rem 1rem;
    }

    /* Topic scope badge */
    .ws-scope-badge {
        background: #fff8e1; border: 1px solid #ffe082;
        border-radius: .375rem; padding: .5rem .75rem; font-size: .875rem;
    }

    /* Workspace kartları */
    .ws-card {
        border-radius: .75rem; padding: 1rem;
        border: 1.5px solid #e2e8f0; background: #fff;
        transition: box-shadow .15s;
    }
    .ws-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,.08); }
    .ws-card-running { border-left: 4px solid #22c55e; }
    .ws-card-stopped { border-left: 4px solid #94a3b8; }
    .ws-card-header {
        display: flex; align-items: flex-start;
        justify-content: space-between; margin-bottom: .75rem;
    }
    .ws-card-title { font-weight: 600; font-size: 1rem; }
    .ws-card-sub   { font-size: .78rem; }
    .ws-card-info  { margin-bottom: .75rem; display: flex; flex-direction: column; gap: .25rem; }
    .ws-info-row   { display: flex; align-items: baseline; gap: .25rem; }
    .ws-card-actions { display: flex; flex-wrap: wrap; gap: .4rem; }

    /* Boş durum */
    .ws-empty-state {
        text-align: center; padding: 4rem 1rem;
    }

    /* Log modal */
    .ws-log-pre {
        background: #1e1e1e; color: #d4d4d4;
        font-size: .78rem; padding: 1rem;
        max-height: 460px; overflow-y: auto;
        margin: 0; white-space: pre-wrap; word-break: break-all;
    }

    /* Yenile spin */
    .spin { animation: spin .7s linear infinite; display: inline-block; }
    @@keyframes spin { to { transform: rotate(360deg); } }
</style>

@code {
    // ── State ─────────────────────────────────────────────────────────────────
    private List<WorkspaceInfo>?                      _workspaces;
    private List<KtuDeYasPortal.Panel.Domain.Entities.Structure>? _structures;
    private KtuDeYasPortal.Panel.Domain.Entities.Structure?       _selectedStructure;

    private bool   _loading     = false;
    private bool   _showCreate  = false;
    private bool   _creating    = false;
    private string _workspaceName = string.Empty;
    private bool   _nameError   = false;
    private bool   _nameInvalidTurkish = false;
    private string? _actionId;         // sil/restart için hangi container işlemdeyse

    private string? _successMsg;
    private string? _errorMsg;

    // Log modal
    private string? _logContainerId;
    private string? _logContainerName;
    private string  _logContent  = string.Empty;
    private bool    _logLoading  = false;

    // ── Lifecycle ─────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    // ── Veri yükleme ──────────────────────────────────────────────────────────
    private async Task RefreshAsync()
    {
        _loading = true;
        _errorMsg = null;
        StateHasChanged();
        try
        {
            _workspaces = await WorkspaceUC.ListWorkspacesAsync();
        }
        catch (Exception ex)
        {
            _errorMsg = $"Workspace listesi alınamadı: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Drawer aç / kapat ─────────────────────────────────────────────────────
    private async Task OpenCreatePanel()
    {
        _showCreate    = true;
        _workspaceName = string.Empty;
        _nameError     = false;
        _nameInvalidTurkish = false;
        _selectedStructure = null;
        _errorMsg = null;

        // Yapı listesini yükle (drawer açılırken)
        if (_structures is null)
        {
            try { _structures = await WorkspaceUC.GetAllStructuresAsync(); }
            catch (Exception ex) { _errorMsg = $"Yapılar yüklenemedi: {ex.Message}"; }
        }
    }

    private void CloseCreatePanel()
    {
        _showCreate = false;
        _selectedStructure = null;
        _workspaceName = string.Empty;
        _nameError = false;
        _nameInvalidTurkish = false;
    }

    // ── Yapı seçimi ───────────────────────────────────────────────────────────
    private void OnStructureSelected(ChangeEventArgs e)
    {
        _selectedStructure = null;
        if (!Guid.TryParse(e.Value?.ToString(), out var id)) return;
        _selectedStructure = _structures?.FirstOrDefault(s => s.Id == id);
    }

    // ── Workspace oluştur ─────────────────────────────────────────────────────
    private async Task CreateWorkspaceAsync()
    {
        _nameError = false;
        _nameInvalidTurkish = false;

        var trimmedName = _workspaceName.Trim();
        if (string.IsNullOrWhiteSpace(trimmedName) || trimmedName.Length < 3)
        {
            _nameError = true;
            return;
        }

        if (ContainsTurkishCharacters(trimmedName))
        {
            _nameInvalidTurkish = true;
            return;
        }

        if (_selectedStructure is null) return;

        _creating = true;
        _errorMsg = null;
        StateHasChanged();

        try
        {
            var result = await WorkspaceUC.CreateAsync(_selectedStructure, _workspaceName.Trim());

            if (result.Success)
            {
                _successMsg = $"✓ Workspace başlatıldı → {result.EditorUrl}";
                CloseCreatePanel();
                await RefreshAsync();
            }
            else
            {
                _errorMsg = $"Workspace oluşturulamadı: {result.Error}";
            }
        }
        catch (Exception ex)
        {
            _errorMsg = $"Hata: {ex.Message}";
        }
        finally
        {
            _creating = false;
        }
    }

    private static bool ContainsTurkishCharacters(string value)
    {
        const string turkishChars = "çğıİşöüÇĞİŞÖÜ";
        return value.Any(c => turkishChars.Contains(c));
    }

    // ── Workspace sil ─────────────────────────────────────────────────────────
    private async Task DeleteWorkspaceAsync(string containerId, string name)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"'{name}' workspace silinecek. Onaylıyor musunuz?");
        if (!confirmed) return;

        _actionId = containerId;
        _errorMsg = null;
        StateHasChanged();

        try
        {
            await WorkspaceUC.DeleteAsync(containerId);
            _successMsg = $"'{name}' workspace silindi.";
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _errorMsg = $"Silme hatası: {ex.Message}";
        }
        finally
        {
            _actionId = null;
        }
    }

    // ── Workspace restart ─────────────────────────────────────────────────────
    private async Task RestartWorkspaceAsync(string containerId)
    {
        _actionId = containerId;
        _errorMsg = null;
        StateHasChanged();

        try
        {
            await WorkspaceUC.RestartAsync(containerId);
            _successMsg = "Workspace yeniden başlatıldı.";
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            _errorMsg = $"Restart hatası: {ex.Message}";
        }
        finally
        {
            _actionId = null;
        }
    }

    // ── Log modal ─────────────────────────────────────────────────────────────
    private async Task OpenLogModal(WorkspaceInfo ws)
    {
        _logContainerId   = ws.ContainerId;
        _logContainerName = ws.WorkspaceName;
        _logContent       = string.Empty;
        await LoadLogsAsync(ws.ContainerId);
    }

    private async Task LoadLogsAsync(string containerId)
    {
        _logLoading = true;
        StateHasChanged();
        try
        {
            _logContent = await WorkspaceUC.GetLogsAsync(containerId, tail: 150);
        }
        catch (Exception ex)
        {
            _logContent = $"Log alınamadı: {ex.Message}";
        }
        finally
        {
            _logLoading = false;
        }
    }

    private void CloseLogModal()
    {
        _logContainerId   = null;
        _logContainerName = null;
        _logContent       = string.Empty;
    }
}
