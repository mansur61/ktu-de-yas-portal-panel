{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Services": {
    "TimeseriesApi": "http://localhost:5000",
    "EdgeApi": "http://localhost:5080",
    "PortalApi": "http://localhost:5050"
  },
  "Panel": {
    "Title": "KTU DeYas Admin Panel",
    "BaseUrl": "http://localhost:5056"
  },
  "MediaSimulation": {
    "UploadTempRoot": "C:\\tmp\\ktu-de-yas-media"
  },
  "SignalR": {
    "Enabled": true,
    "HubPath": "/hubs/sensor",
    "PortalHubUrl": "http://localhost:5050/hubs/dashboard"
  },
  "Grafana": {
    "BaseUrl": "http://localhost:3000",
    "TimeseriesDashboard": "iot-platform-timeseries",
    "TimeseriesSlug": "iot-platform-timescaledb",
    "DefaultTimeRange": "1h"
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "Enabled": false
  }
}
