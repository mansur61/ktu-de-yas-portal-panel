<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="deyas-local" value="../../ktu-de-yas-shared/artifacts" />
    <add key="github-deyas" value="https://nuget.pkg.github.com/mansur61/index.json" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="deyas-local">
      <package pattern="DeYas.*" />
    </packageSource>
    <packageSource key="github-deyas">
      <package pattern="DeYas.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
